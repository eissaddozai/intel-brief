                  &lt;div class="c-related-tags u-dn u-db@m"&gt;
  &lt;h4&gt;Related Tags&lt;/h4&gt;
  &lt;ul class="o-list o-list--vertical"&gt;
                              &lt;li class="u-pad-b20"&gt;&lt;a href="https://www.crisisgroup.org/middle-east-north-africa/gulf-and-arabian-peninsula/iran" class="u-ttu"&gt;&lt;small class="u-black"&gt;Iran&lt;/small&gt;&lt;/a&gt;&lt;/li&gt;

                              &lt;li class="u-pad-b20"&gt;&lt;a href="https://www.crisisgroup.org/middle-east-north-africa/east-mediterranean-mena/israelpalestine" class="u-ttu"&gt;&lt;small class="u-black"&gt;Israel/Palestine&lt;/small&gt;&lt;/a&gt;&lt;/li&gt;

                              &lt;li class="u-pad-b20"&gt;&lt;a href="https://www.crisisgroup.org/north-america" class="u-ttu"&gt;&lt;small class="u-black"&gt;United States&lt;/small&gt;&lt;/a&gt;&lt;/li&gt;

