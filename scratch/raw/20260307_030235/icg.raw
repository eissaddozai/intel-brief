                  &lt;a href="https://www.crisisgroup.org/qna/latin-america-caribbean/venezuela/us-snaps-venezuelas-oil-and-rare-minerals-race-supplies" class="[ u-df u-jcfs u-aic u-width-100 ] [ u-pad-l15 u-pad-r15 u-pad-t15 u-pad-b15 ]"&gt;
                    &lt;span class="o-icon o-icon--sm"&gt;&lt;svg&gt;&lt;use xlink:href="#check" xmlns:xlink="http://www.w3.org/1999/xlink" /&gt;&lt;/svg&gt;&lt;/span&gt;
                    &lt;span class="u-mar-l10 u-gray--light u-width-100 [ u-tal u-wbbw u-tofe u-wsnw u-ofh ]"&gt;
