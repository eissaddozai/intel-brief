          &lt;/li&gt;
                                &lt;li class="c-side-nav__list__item"&gt;
            &lt;a href="javascript:;" class="u-ttu js-side-nav__item" data-target="subregion-middle-east-north-africa" data-depth="2"&gt;Middle East &amp;amp; North Africa&lt;span class="o-icon o-icon--xxs"&gt;&lt;svg&gt;&lt;use xlink:href="#chevron-right" xmlns:xlink="http://www.w3.org/1999/xlink" /&gt;&lt;/svg&gt;&lt;/span&gt;&lt;/a&gt;
          &lt;/li&gt;
                                &lt;li class="c-side-nav__list__item"&gt;
            &lt;a href="javascript:;" class="u-ttu js-side-nav__item" data-target="subregion-united-states" data-depth="2"&gt;United States&lt;span class="o-icon o-icon--xxs"&gt;&lt;svg&gt;&lt;use xlink:href="#chevron-right" xmlns:xlink="http://www.w3.org/1999/xlink" /&gt;&lt;/svg&gt;&lt;/span&gt;&lt;/a&gt;
          &lt;/li&gt;
                  &lt;/ul&gt;
  
    &lt;ul class="o-list o-list--vertical c-side-nav__list u-ls-025"&gt;
    &lt;li class="c-side-nav__list__item"&gt;&lt;a href="https://www.crisisgroup.org/gender-and-conflict" class="u-ttu"&gt;Gender &amp;amp; Conflict&lt;/a&gt;&lt;/li&gt;
    &lt;li class="c-side-nav__list__item"&gt;&lt;a href="javascript:;" class="u-ttu js-side-nav__item" data-target="future_conflict" data-depth="2"&gt;Future of Conflict&lt;span class="o-icon o-icon--xxs"&gt;&lt;svg&gt;&lt;use xlink:href="#chevron-right" xmlns:xlink="http://www.w3.org/1999/xlink" /&gt;&lt;/svg&gt;&lt;/span&gt;&lt;/a&gt;&lt;/li&gt;
    &lt;li class="c-side-nav__list__item"&gt;&lt;a href="javascript:;" class="u-ttu js-side-nav__item" data-target="topics" data-depth="2"&gt;Global Issues&lt;span class="o-icon o-icon--xxs"&gt;&lt;svg&gt;&lt;use xlink:href="#chevron-right" xmlns:xlink="http://www.w3.org/1999/xlink" /&gt;&lt;/svg&gt;&lt;/span&gt;&lt;/a&gt;&lt;/li&gt;
    &lt;li class="c-side-nav__list__item"&gt;&lt;a href="javascript:;" class="u-ttu js-side-nav__item" data-target="visual-explainer" data-depth="2"&gt;Visual Explainers&lt;span class="o-icon o-icon--xxs"&gt;&lt;svg&gt;&lt;use xlink:href="#chevron-right" xmlns:xlink="http://www.w3.org/1999/xlink" /&gt;&lt;/svg&gt;&lt;/span&gt;&lt;/a&gt;&lt;/li&gt;
  &lt;/ul&gt;

    &lt;ul class="o-list o-list--vertical c-side-nav__list u-ls-025"&gt;
    &lt;li class="c-side-nav__list__item"&gt;&lt;a href="https://www.crisisgroup.org/reading-list" class="u-ttu"&gt;My Reading List&lt;/a&gt;&lt;/li&gt;
                      &lt;li class="c-side-nav__list__item"&gt;
