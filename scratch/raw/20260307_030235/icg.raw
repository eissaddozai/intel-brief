                     /  &lt;a href="https://www.crisisgroup.org/global"&gt;Global&lt;/a&gt;
            &lt;time datetime="03/06/2026 - 19:07" class="u-mar-l15 u-dib"&gt;06 March 2026&lt;/time&gt;
              &lt;strong class="node-read-time u-mar-l15 u-fwn"&gt;&lt;span class="o-icon o-icon--sm o-icon--stopwatch"&gt;&lt;svg&gt;&lt;use xlink:href="#stopwatch" xmlns:xlink="http://www.w3.org/1999/xlink" /&gt;&lt;/svg&gt;&lt;/span&gt;15 minutes&lt;/strong&gt;
