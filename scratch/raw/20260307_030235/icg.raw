        &lt;strong&gt;Commentary&lt;/strong&gt;
      &lt;/a&gt;
                     /  &lt;a href="https://www.crisisgroup.org/middle-east-north-africa"&gt;Middle East &amp;amp; North Africa&lt;/a&gt;
            &lt;time datetime="03/06/2026 - 19:51" class="u-mar-l15 u-dib"&gt;06 March 2026&lt;/time&gt;
              &lt;strong class="node-read-time u-mar-l15 u-fwn"&gt;&lt;span class="o-icon o-icon--sm o-icon--stopwatch"&gt;&lt;svg&gt;&lt;use xlink:href="#stopwatch" xmlns:xlink="http://www.w3.org/1999/xlink" /&gt;&lt;/svg&gt;&lt;/span&gt;20+ minutes&lt;/strong&gt;
