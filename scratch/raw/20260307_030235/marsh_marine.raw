							    </div>
							</div>
							<input type="hidden" name="locale" value="en_US"/>
							<input type="hidden" name="site" value="marsh"/>
							<input type="hidden" id="contentPath" name="path" value="/content/marsh2/en_us/industries/marine/insights"/>
							<input type="hidden" id="appId" name="appId" value="marshcom"/>
							<input type="hidden" id="ACSIdx" name="ACSIdx" value="1"/>
							<input type="hidden" id="pingInErrorResource" name="pingInErrorResource" value="https://www.marsh.com/en/registration-form.html"/>
							<input type="hidden" name="mfadevicePrint" id="mfadevicePrint"/>							
							<div class="row c-form-fieldset">
							    <div class="large-10 medium-10 small-12 small-centered columns">
							        <input class="submit-button arrow-right disabled" id="loginButton" name="loginButton" type="submit" value="Sign in"/>                              
							        <div class="options">
							        	<a href="https://ampsui.digitalsso.com/ampsui/ResetPassword?locale=en_US&site=marsh&appId=marshcom">Forgot password</a>
										  
										<a href="/en/registration-form.html">Register</a>
									</div>
							        <p><span>*</span>Required</p>
							    </div>
							    <script>
			                        $(document).ready(function(){
										
			                        	
			                            $("#modalWindow").on('change', '#emailAddress,#logPassword', function() {
			                                $(this).val(trimTrailingSpaces($(this).val()));
			                            });
			                        });
			                     
			                        
			                        function trimTrailingSpaces(text){
			                            return text.replace(/^\s*/, "").replace(/\s*$/, "");
			                        }
			                    </script>
