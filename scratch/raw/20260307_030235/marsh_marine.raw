   <script defer="defer" type="text/javascript" src="https://rum.hlx.page/.rum/@adobe/helix-rum-js@%5E2/dist/rum-standalone.js" data-routing="env=prod,tier=publish,ams=Marsh McLennan Company"></script>
<script>
	var cookieValue = getCookieValue('countryCode');
    const currentCountryCode = getCookieValue('currentCountryCode');
    if (currentCountryCode.toLowerCase() === 'au') {
        const pathName = window.location.pathname.substring(1);
        const isoCodeFromURI = pathName.substring(0, pathName.indexOf("/"));
        let isGlobalNavAutoUpdatedCookie = getCookieValue('isGlobalNavAutoUpdated');
        isGlobalNavAutoUpdatedCookie = isGlobalNavAutoUpdatedCookie === 'true';
        const didUserSelectAUAgain = cookieValue === 'AU';
        let isCurrentPageApprovedForAustralia = document.querySelector('meta[name="isApprovedForAustralia"]')?.content;
        isCurrentPageApprovedForAustralia = isCurrentPageApprovedForAustralia === "true";
        console.log("isGlobalNavAutoUpdated:", isGlobalNavAutoUpdatedCookie);
        if (isoCodeFromURI.toLowerCase() !== 'en-gb') {
            if (didUserSelectAUAgain || isGlobalNavAutoUpdatedCookie) {
                cookieValue = 'ZZ';
                console.log('URL is not EN-GB and User has not changed the country from global nav: ZZ Global');
            } else {
                console.log('URL is not EN-GB and User has changed the country from global nav to some other region:', cookieValue);
            }
        } else {
            if (isCurrentPageApprovedForAustralia) {
                if (isGlobalNavAutoUpdatedCookie) {
                    console.log('Current Page is approved for AU | URL is EN-GB and User has not changed the country from global nav: AU');
                    cookieValue = 'AU';
                } else {
                    console.log('Current Page is approved for AU | URL is EN-GB and User has changed the country from global nav to some other region like UK:', cookieValue);
                }
            } else {
                if (didUserSelectAUAgain) {
                    cookieValue = 'ZZ';
                    console.log('Current Page is not approved for AU | URL is EN-GB so set to global');
                }
            }
        }
    }

	//function to get cookie value
    function getCookieValue(cookieName) {
        // Split all the cookies into an array
        var cookies = document.cookie.split(';');
        // Loop through the array to find the desired cookie
        for (var i = 0; i < cookies.length; i++) {
            var cookie = cookies[i].trim();
            // Check if the cookie starts with the desired name
            if (cookie.startsWith(cookieName + '=')) {
                // Extract and return the cookie value
                return cookie.substring(cookieName.length + 1);
            }
        }
        // Return null if the cookie is not found
        return null;
    }
	
	//function to target param
    function targetPageParams() {
        return {
            "at_property": "8db83558-1f8b-7c88-7d3f-41ba58e8b291",
            "countryCode": cookieValue
        };
    }
</script>


    
    
