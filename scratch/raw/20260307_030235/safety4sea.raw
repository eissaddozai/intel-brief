/* JNews about widget (blurb) massive CSS */

@media screen and (max-width: 766px){
.blurb-row .vc_column_container {
	width: 93%;
	margin-bottom: 20px;
}
}

@media screen and (min-width: 1024px) and (max-width: 1024px){
.blurb-row .vc_column_container {
	width: 93%;
	margin-bottom: 20px;
}
.blurb-row .jeg-vc-wrapper{
	display: block;
}
}

@media screen and (min-width: 767px) and (max-width: 1023px){
.blurb-row .vc_column_container {
	width: 45%;
}
	.blurb-row .jeg-vc-wrapper{
	display: flex;
}
}

@media screen and (min-width: 1025px) {
.blurb-row .vc_column_container {
	width: 45%;
}
	.blurb-row .jeg-vc-wrapper{
	display: flex;
}
}

.blurb-row .vc_column_container{
	margin-left: 15px;
	margin-right: 15px;
	padding-left: 0;
	padding-right: 0;
	border: 2px solid #0087cd;
	margin-bottom: 15px;
}



.blurb-row .jeg_about {
	display: flex;
	flex-direction: column;

}
.blurb-row .jeg_about .footer_logo {
	margin-bottom: 0px;
	padding: 20px;
	background-color: #0087cd;
	pointer-events: none;
}

.blurb-row .jeg_about .footer_logo img{
	width: 100px;
}

.blurb-row .jeg_about .jeg_about_name {
	margin-bottom: 0px;
	padding: 0 10px 0 10px;
	background-color: #0087cd;
	color: #fff;
}

.blurb-row .jeg_about .jeg_about_title {
	background-color: #0087cd;
	color: #fff;
	margin-bottom: 0;
	padding: 0 10px;
	font-style: normal;
	line-height: normal;
	min-height: 50px;
	font-size: 14px;

}

.blurb-row .jeg_about p:nth-child(4) {
	padding: 10px;
	font-size: .85em;
	line-height: normal;
	margin-bottom: 5px;
	text-align: left!important;
}




/* RISK4SEA Sidebar QUOTES COLLECTION Widget CSS*/

#custom_html-20,#custom_html-21{
	padding: 0;
	border: 1px solid #c00000;
	background:#fff;
}


#custom_html-20 .learn-more-r4s,#custom_html-21 .learn-more-r4s{
	background: #3F3939;
	padding: 10px;
	color: #ffffff;
	font-weight: bold;
	text-align: center;
	font-size: 18px;
}

#custom_html-20 .learn-more-r4s a,#custom_html-21 .learn-more-r4s a{
	color: #ffffff;
}


#custom_html-20 .jeg_block_heading,#custom_html-21 .jeg_block_heading {
	background: #c00000;
	margin-bottom: 0;
	font-size: 18px!important;
}

#custom_html-20 .jeg_footer_title,#custom_html-21 .jeg_footer_title {
	color: #fff;
	margin-left: 3%;
	text-transform: uppercase;
	padding:5px;
}

#custom_html-20 .jeg_footer_heading,#custom_html-21 .jeg_footer_heading {
	background: #c00000;
	margin-bottom: 0;
	font-size: 18px!important;
}

#custom_html-20 .jeg_block_heading span, #custom_html-21 .jeg_block_heading span {
	font-size: 18px!important;
}

#custom_html-20 .jeg_footer_heading span,#custom_html-21 .jeg_footer_heading span {
	font-size: 18px!important;
}

.r4s-facts{
	font-weight: bold!important;
}


