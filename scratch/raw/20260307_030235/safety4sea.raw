/* Custom Pull Quote Icons */

.pullquote:before{
	content: "\201C"!important;
	font-size: 120%!important;
	width: 0!important;
	margin: 0!important;
	display: inline!important;
	background: transparent!important;
}

.pullquote:after{
	content: "\201D"!important;
	font-size: 120%!important;
	width: 0!important;
	margin: 0!important;
	display: inline!important;
	background: transparent!important;
	/*position: absolute!important;
	margin-top: 4%!important;*/
}

.pullquote p{
	display: inline!important;
	color: #212121;
}

/* DropCap Style */
.entry-content .dropcap{
	text-shadow: 5px 5px #eee;
    font-size: 6em;
    margin-bottom: -5px;
    font-family: 'Libre Baskerville',Georgia,serif;
}

/* Make intro text of old articles like the Jnews theme */
.entry-content h4{
	  font-size: 1.5em;
    line-height: 1.458em;
    color: #212121;
    letter-spacing: -.01em;
	font-family: "Droid Serif",Helvetica,Arial,sans-serif;
	font-weight:500;
	
}

/* Dropcap effect for old articles */
.first-p:first-of-type::first-letter {
       text-shadow: 5px 5px #eee;
    font-size: 6em;
    margin-bottom: -5px;
    font-family: 'Libre Baskerville',Georgia,serif;
      display: block;
    float: left;
    margin: .04em .2em 0 0;
    color: #212121;
  
    line-height: 1;
}

blockquote:not(.pullquote){
	font-size: 24px;
	border: none;
	padding: 0;
	position: relative;
	text-align: center;
	margin: 1.25em auto;
	padding: .5em 12%;
}

blockquote:not(.pullquote):before {
    content: "\201C"!important;
    font-size: 120%!important;
    width: 0!important;
    margin: 0!important;
    display: inline!important;
    background: transparent!important;
}


blockquote:not(.pullquote):after {
    content: "\201D"!important;
    font-size: 120%!important;
    width: 0!important;
    margin: 0!important;
    display: inline!important;
    background: transparent!important;
}

blockquote:not(.pullquote) p {
	display: inline;
}
}


