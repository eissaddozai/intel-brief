		<script>
	
	// Function to open the popup
	function openPopup() {
		const popup = document.getElementById('newsletter-popup');
		const overlay = document.getElementById('overlay');
		popup.style.display = 'flex'; // Show the popup
		overlay.style.display = 'block'; // Show the dark overlay
		sessionStorage.setItem('popupDisplayed', 'true'); // Mark as shown in session storage
	}
	
	// Function to close the popup and overlay
	function closePopup() {
		const popup = document.getElementById('newsletter-popup');
		const overlay = document.getElementById('overlay');
		popup.style.display = 'none';
		overlay.style.display = 'none';
		sessionStorage.setItem('popupClosed', 'true'); // Mark as closed for this session
	}
	
	// Function to close the popup when clicking outside it (on the overlay)
	function closePopupOnOverlayClick(event) {
		if (event.target === document.getElementById('overlay')) {
			closePopup();
		}
	}
	
	// Function to show the popup when the user scrolls to the footer
	function showPopupOnFooterScroll() {
		const footer = document.querySelector('footer');
	
		const onScroll = () => {
			const footerPosition = footer.getBoundingClientRect().top;
			const screenHeight = window.innerHeight;
	
			// Check if footer is in view
			if (footerPosition < screenHeight) {
				openPopup();
				window.removeEventListener('scroll', onScroll); // Remove event to show only once
			}
		};
	
		window.addEventListener('scroll', onScroll);
	}
	
	// Function to handle form submission
	function handleFormSubmit() {
			const form = document.querySelector('#newsletter-popup form');
			const fullNameField = document.getElementById('full-name');
			const errorContainer = document.createElement('div');
			errorContainer.className = 'error-message';
			form.appendChild(errorContainer);

			form.addEventListener('submit', function (e) {
				const fullNameValue = fullNameField.value.trim();
				const captchaResponse = grecaptcha.getResponse();

				errorContainer.textContent = ''; // Clear previous error messages

				// Validate Full Name field: 2-3 words, only alphabetic characters
				const nameRegex = /^[a-zA-Z]+( [a-zA-Z]+){1,2}$/; // Regex for validation
				if (!nameRegex.test(fullNameValue)) {
					e.preventDefault(); // Stop form submission
					errorContainer.textContent = 'Please enter a valid full name with 2 to 3 alphabetic words.';
					return;
				}

				// Validate reCAPTCHA client-side
				if (!captchaResponse) {
					e.preventDefault(); // Stop form submission
					errorContainer.textContent = 'Please complete the reCAPTCHA to submit the form.';
					return;
				}

				// Allow submission if all validations pass
				sessionStorage.setItem('formSubmitted', 'true');
			});
		}
	
	// Function to initialize both timer and footer scroll trigger
	function initPopupTriggers() {
		if (!sessionStorage.getItem('popupClosed')) {
			if (sessionStorage.getItem('formSubmitted')) {
				openPopup(); // Keep the popup open if the form was submitted
			} else {
				setTimeout(() => {
					if (!sessionStorage.getItem('popupDisplayed')) {
						openPopup();
					}
				}, 30000); // Show popup after 30 seconds
	
				showPopupOnFooterScroll();
			}
		}
	}
	
	// Initialize the popup and form validation on DOM load
	document.addEventListener('DOMContentLoaded', () => {
		const popup = document.getElementById('newsletter-popup');
