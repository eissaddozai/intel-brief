&lt;p&gt;&lt;strong style="vertical-align: baseline;"&gt;ANGRYREBEL.LINUX&lt;/strong&gt;&lt;span style="vertical-align: baseline;"&gt; sample&lt;/span&gt;&lt;/p&gt;
&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td style="vertical-align: middle; border: 1px solid #000000; padding: 16px;"&gt;
