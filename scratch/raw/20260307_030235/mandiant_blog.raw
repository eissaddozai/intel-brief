&lt;div class="block-paragraph_advanced"&gt;&lt;h5&gt;&lt;span style="vertical-align: baseline;"&gt;Modules&lt;/span&gt;&lt;/h5&gt;&lt;/div&gt;
&lt;div class="block-paragraph_advanced"&gt;&lt;div align="center"&gt;
