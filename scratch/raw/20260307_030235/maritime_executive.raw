    // Wait for jQuery to be available before executing jQuery-dependent code
    function waitForJQuery(callback) {
        if (typeof jQuery !== 'undefined' && jQuery) {
            callback();
        } else {
            setTimeout(function() {
                waitForJQuery(callback);
            }, 10);
        }
    }

