      <RelatedItemID1 />
      <RelatedItemID2 />
      <RelatedItemID3 />
      <Author>BY SARA BAZOOBANDI</Author>
      <Sponsored>False</Sponsored>
      <Tags>Iran,Ayatollah Ali Khamenei,Tehran,Jerusalem Report,Islamic Republic,Operation Epic Fury,Operation Roaring Lion</Tags>
      <CategoryID>24</CategoryID>
      <SocialTitle>Iran after Khamenei: Hope, fear, and uncertainty</SocialTitle>
    </item>
