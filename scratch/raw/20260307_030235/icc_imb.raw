<script type="text/javascript">
jQuery(document).ready(function ($) {
    var hireFreightSelect = $('select[name="hire_freight_paid"]');
    var additionalDetailsContainer = $('#additional-details-container');
	

    additionalDetailsContainer.hide();

    hireFreightSelect.on('change', function () {
        if ($(this).val() === "No") {
            additionalDetailsContainer.show();
        } else {
			additionalDetailsContainer.hide();
		}
    });
	
	var issuesWithOtherPayments = $('select[name="issues_with_other_payments"]');
    var additionalDetailsContainerIWOP = $('#issues-with-other-payments');
	

    additionalDetailsContainerIWOP.hide();

    issuesWithOtherPayments.on('change', function () {
		console.log($(this).val());
        if ($(this).val() === "Yes") {
            additionalDetailsContainerIWOP.show();
        } else {
			additionalDetailsContainerIWOP.hide();
		}
    });

	  var anyOtherIssues = $('select[name="any_other_issues"]');
	  var additionalDetailsIssueContainer = $('#additional-details-issue-container');
	
	
	   additionalDetailsIssueContainer.hide();

    anyOtherIssues.on('change', function () {
        if ($(this).val()) {
            additionalDetailsIssueContainer.show();
        } else {
			additionalDetailsIssueContainer.hide();
		}
    });
});
</script>

