:[{\"_key\":\"41edc976d6e1\",\"_type\":\"span\",\"marks\":[],\"text\":\"President Massoud Pezeshkian is facing growing criticism from political figures and analysts for failing to seize what some viewed as a rare opportunity to de-escalate the regional conflict while repairing the state’s broken relationship with Iranians.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"publishedAt\":\"2026-03-06T17:07:00.000Z\",\"shorthandUrl\":null,\"slug\":\"202603068645\",\"tag\":{\"color\":\"#0084bc\",\"id\":\"73b1863d-5f72-4a43-a578-40a59fc0e60b\",\"slug\":\"insight\",\"title\":\"INSIGHT\"},\"tags\":[{\"color\":\"#0084bc\",\"id\":\"73b1863d-5f72-4a43-a578-40a59fc0e60b\",\"slug\":\"insight\",\"title\":\"INSIGHT\"}],\"type\":\"article\"},{\"authors\":[{\"id\":\"9d1f2971-60e4-4ead-a91f-9e4de20f72a8\",\"image\":{\"_type\":\"figure\",\"alt\":\"Negar Mojtahedi \",\"asset\":{\"_ref\":\"image-c8d97cf79269158b3befa7106414ac9945918ade-964x868-jpg\",\"_type\":\"reference\"},\"caption\":\"Negar Mojtahedi \",\"crop\":{\"_type\":\"sanity.imageCrop\",\"bottom\":0,\"left\":0,\"right\":0,\"top\":0},\"hotspot\":{\"_type\":\"sanity.imageHotspot\",\"height\":1,\"width\":1,\"x\":0.5,\"y\":0.5}},\"name\":\"Negar Mojtahedi\",\"slug\":\"negar-mojtahedi\"}],\"headline\":\"Objective of US-Israel campaign is to remove Iran regime, Senator Cruz says\",\"id\":\"39991b4c-58f9-470a-a72e-5cbf3cc27559\",\"image\":{\"alt\":\"Republican Senator Ted Cruz appearing on Eye for Iran. \",\"asset\":{\"_ref\":\"image-243af8ae9124115c2923315233ed39e33d775b6c-1920x1080-jpg\",\"_type\":\"reference\"},\"crop\":{\"_type\":\"sanity.imageCrop\",\"bottom\":0,\"left\":0,\"right\":0,\"top\":0.06549940559135928},\"hotspot\":{\"_type\":\"sanity.imageHotspot\",\"height\":0.9345005944086408,\"width\":1,\"x\":0.5,\"y\":0.5327497027956796},\"metadata\":{\"dimensions\":{\"height\":1080,\"width\":1920},\"lqip\":\"data:image/jpeg;base64,\"}},\"language\":\"english\",\"lead\":[{\"_key\":\"111e24487e08\",\"_type\":\"block\",\"children\":[{\"_key\":\"9a0b2b887d85\",\"_type\":\"span\",\"marks\":[],\"text\":\"US Senator Ted Cruz told Iran International this week that the US-Israel military campaign aims to remove the Islamic Republic from power and diminish Tehran’s ability to “terrorize” or harm its neighbors.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"publishedAt\":\"2026-03-06T08:22:24.044Z\",\"shorthandUrl\":null,\"slug\":\"202603060327\",\"tag\":{\"color\":\"#82059f\",\"id\":\"648a7c64-99e4-44f1-95b8-b50c55471213\",\"slug\":\"podcast\",\"title\":\"PODCAST\"},\"tags\":[{\"color\":\"#82059f\",\"id\":\"648a7c64-99e4-44f1-95b8-b50c55471213\",\"slug\":\"podcast\",\"title\":\"PODCAST\"}],\"type\":\"article\"},{\"authors\":[{\"id\":\"190ffc74-d9df-4f08-bef9-98e1aefcfe0e\",\"image\":{\"_type\":\"figure\",\"alt\":\"Maryam Sinaee, British Iranian journalist\",\"asset\":{\"_ref\":\"image-45ee979fa99e8002d6eaa062959bc17d6e4fd2ff-1520x2026-jpg\",\"_type\":\"reference\"},\"caption\":\"Maryam Sinaiee\"},\"name\":\"Maryam Sinaiee\",\"slug\":\"maryam-sinaiee\"}],\"headline\":\"Fears grow for Iranian prisoners as war raises risk of another Evin disaster\",\"id\":\"de4153fc-d202-4fe4-bb2e-2a9dc40fef3f\",\"image\":{\"alt\":null,\"asset\":{\"_ref\":\"image-3e7e160277f7265ee2ef5f6c4b5a192d9ded416f-780x470-jpg\",\"_type\":\"reference\"},\"crop\":{\"_type\":\"sanity.imageCrop\",\"bottom\":0,\"left\":0,\"right\":0,\"top\":0},\"hotspot\":{\"_type\":\"sanity.imageHotspot\",\"height\":0.9926697343562613,\"width\":1,\"x\":0.5,\"y\":0.5036651328218693},\"metadata\":{\"dimensions\":{\"height\":470,\"width\":780},\"lqip\":\"data:image/jpeg;base64,\"}},\"language\":\"english\",\"lead\":[{\"_key\":\"50e1367fa93f\",\"_type\":\"block\",\"children\":[{\"_key\":\"940706e633e9\",\"_type\":\"span\",\"marks\":[],\"text\":\"Human rights groups and families of detainees warn that wartime conditions inside Iranian prisons could trigger another tragedy like the June strike on Tehran’s Evin prison.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"