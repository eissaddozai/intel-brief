ound-color:var(--wp--custom--color--text--primary);content:"";display:inline-block;height:var(--icon-size);-webkit-mask-position:center;mask-position:center;-webkit-mask-repeat:no-repeat;mask-repeat:no-repeat;-webkit-mask-size:contain;mask-size:contain;width:var(--icon-size);-webkit-mask-image:url("/app/themes/pulsar/build/css/blocks/../../../assets/svg/list-arrow.svg");mask-image:url("/app/themes/pulsar/build/css/blocks/../../../assets/svg/list-arrow.svg");left:0;position:absolute;top:8px}.is-style-surface-primary .wp-block-list:where(.is-style-arrows):where(ul) li::before{background-color:var(--wp--custom--color--surface--accent)}

