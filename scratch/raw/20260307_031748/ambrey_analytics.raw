<style id='nebula-blocks-featured-media-style-inline-css'>
.wp-block-nebula-blocks-featured-media{display:grid;grid-template-columns:1fr;grid-template-rows:1fr;overflow:clip}.wp-block-nebula-blocks-featured-media .wp-block-nebula-blocks-featured-media__media{grid-column:1/-1;grid-row:1/-1;height:70vh;isolation:isolate;position:relative}.wp-block-nebula-blocks-featured-media .wp-block-nebula-blocks-featured-media__media::after{background-image:linear-gradient(to top, var(--wp--custom--color--surface--primary), transparent);background-position:center;content:"";top:0;right:0;bottom:0;left:0;opacity:.65;position:absolute;z-index:1}.wp-block-nebula-blocks-featured-media .wp-block-nebula-blocks-featured-media__media img,.wp-block-nebula-blocks-featured-media .wp-block-nebula-blocks-featured-media__media video{height:100%;-o-object-fit:cover;object-fit:cover;-o-object-position:50% 50%;object-position:50% 50%;overflow:clip;width:100%}.wp-block-nebula-blocks-featured-media .wp-block-nebula-blocks-featured-media__container{grid-column:1/-1;grid-row:1/-1;padding:var(--wp--preset--spacing--4-xl) var(--wp--style--root--padding-right) var(--wp--preset--spacing--6-xl) var(--wp--style--root--padding-left);z-index:1}.wp-block-nebula-blocks-featured-media .wp-block-nebula-blocks-featured-media__inner{display:flex;flex-direction:column;height:100%;justify-content:space-between;margin-left:auto;margin-right:auto;max-width:var(--wp--custom--layout--wide)}.wp-block-nebula-blocks-featured-media .wp-block-nebula-blocks-featured-media__content{display:flex;flex-direction:column;gap:var(--wp--preset--spacing--2-xl);justify-content:space-between}@media(min-width: 768px){.wp-block-nebula-blocks-featured-media .wp-block-nebula-blocks-featured-media__content{align-items:center;flex-direction:row-reverse}}.wp-block-nebula-blocks-featured-media .wp-block-nebula-blocks-featured-media__title{color:var(--wp--custom--color--text--invert);margin-top:0}.wp-block-nebula-blocks-featured-media .wp-block-nebula-blocks-featured-media__text{color:var(--wp--custom--color--text--invert);margin-top:0;max-width:75ch;width:100%}.wp-block-nebula-blocks-featured-media .wp-block-nebula-blocks-featured-media__cta{flex:0 0 auto}.wp-block-nebula-blocks-featured-media .wp-block-button__link{background-color:var(--wp--custom--color--surface--accent);color:var(--wp--custom--color--text--primary)}.wp-block-nebula-blocks-featured-media .wp-block-button__link:focus-visible{background-color:var(--wp--custom--color--focus);color:var(--wp--custom--color--text--primary)}

