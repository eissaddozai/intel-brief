function manageBanner() {
  const banner = document.getElementById("nav-banner-2");
  const closeButton = document.getElementById("nav-banner-close-2");
  const storageKey = "bannerClosedUntil";

  const now = new Date().getTime();
  const closedUntil = localStorage.getItem(storageKey);

  // Agar 30 din complete nahi huay → banner hide rahe
  if (closedUntil && now < closedUntil) {
    banner.style.display = "none";
    return;
  }

  // Warna banner show ho
  banner.style.display = "block";

  // Close button click
  closeButton.addEventListener("click", () => {
    banner.style.display = "none";

    // 30 days ka time set karo
    const thirtyDays = 30 * 24 * 60 * 60 * 1000;
    const expiryTime = now + thirtyDays;

    localStorage.setItem(storageKey, expiryTime);
  });
}

document.addEventListener("DOMContentLoaded", manageBanner);
</script></div></div><div data-animation="default" data-collapse="medium" data-duration="400" data-easing="ease" data-easing2="ease" role="banner" class="navigation w-nav"><div class="html-embed-15 w-embed"><style>
