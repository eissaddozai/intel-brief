<script>
function logos() {

let splides = $('#logos');
for ( let i = 0, splideLength = splides.length; i < splideLength; i++ ) {
	new Splide( splides[ i ], {
  perPage: 5,
  arrows: true,
  pagination: false,
  focus: 'center',
  direction: 'ltr',
  gap: '1.5rem',
  type: 'loop',
  autoScroll: {
    autoStart: true,
    speed: 1,
  },
  intersection: {
    inView: {
      autoScroll: true,
    },
    outView: {
      autoScroll: false,
    },
   },
  breakpoints: {
     1320: {
      perPage: 5,
		},
    1080: {
      perPage: 5,
		},
    992: {
      perPage: 5,
		},
    780: {
      perPage: 4,
		},
    479: {
      perPage: 3,
		},
   }
} ).mount( window.splide.Extensions );
}

}
logos();
</script>




