picked up ahead of summer, with C/SOV charter rates averaging ~€50,000/day in Europe, reflecting expectations of another tight market and limited vessel availability across the coming summer.","KeyWords":null,"LastUpdated":"0001-01-01T00:00:00","PublishedOn":"2026-02-18T00:00:00","UseContentForSynopsis":false,"Authors":[{"Name":"Clarksons Research"}],"Url":"https://sin.clarksons.net/News/Article/221250","RoleRestrictionsJson":"{\"DefaultRestriction\": \"Show\"}","DocumentLinkRoleRestrictionsJson":"{\"DefaultRestriction\": \"Show\"}","IsSticky":false,"HasContent":true,"ArticleTemplateId":null,"RequiresTrialistOrSubscriberAccess":true,"IsPublished":0,"ArticleEntityLinks":[{"CategoryId":1450,"ArticleId":0,"Summary":null,"Type":1,"Title":"Wind","MatchCount":null},{"CategoryId":1041,"ArticleId":0,"Summary":null,"Type":1,"Title":"Analysis","MatchCount":null},{"CategoryId":1042,"ArticleId":0,"Summary":null,"Type":1,"Title":"Briefings","MatchCount":null},{"CategoryId":1463,"ArticleId":0,"Summary":null,"Type":1,"Title":"Sector Outlook","MatchCount":null},{"CategoryId":1451,"ArticleId":0,"Summary":null,"Type":1,"Title":"RIN","MatchCount":null},{"CategoryId":1429,"ArticleId":221250,"Summary":null,"Type":1,"Title":"SIN","MatchCount":null},{"TsSeriesId":10318751,"TimeseriesSortOrder":1,"ArticleId":221250,"Summary":"(WOR, OIN, RIN) Freq: A, Unit: Capacity (GW), Active > Renewables > Wind Farms, Active > Renewables > Wind Farms","Type":6,"Title":"Active > Wind Farms","MatchCount":null},{"TsSeriesId":10318762,"TimeseriesSortOrder":2,"ArticleId":221250,"Summary":"(WOR, OIN, RIN) Freq: A, Unit: Capacity (GW), In Development > Renewables > Wind Farms, In Development > Renewables > Wind Farms","Type":6,"Title":"Start-Ups > Wind Farms","MatchCount":null},{"TsSeriesId":10336220,"TimeseriesSortOrder":3,"ArticleId":221250,"Summary":"(RIN) Freq: A, Unit: $m","Type":6,"Title":"FID > Offshore Wind Investment (With Forecast)","MatchCount":null},{"TsSeriesId":558428,"TimeseriesSortOrder":4,"Art