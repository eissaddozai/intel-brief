所上涨。2025年以来新造船价格指数已小幅回落2.5%，较2024年9月的高点回落约2.9%，较2008年11月历史峰值的差距约3.7%。","KeyWords":null,"LastUpdated":"0001-01-01T00:00:00","PublishedOn":"2025-12-08T00:00:00","UseContentForSynopsis":false,"Authors":[{"Name":"Clarksons Research"}],"Url":"https://sin.clarksons.net/News/Article/218692","RoleRestrictionsJson":"{\"DefaultRestriction\": \"Show\"}","DocumentLinkRoleRestrictionsJson":"{\"DefaultRestriction\": \"Show\"}","IsSticky":false,"HasContent":true,"ArticleTemplateId":null,"RequiresTrialistOrSubscriberAccess":true,"IsPublished":0,"ArticleEntityLinks":[{"CategoryId":1427,"ArticleId":0,"Summary":null,"Type":1,"Title":"中文 (Chinese Language)","MatchCount":null},{"CategoryId":1466,"ArticleId":0,"Summary":null,"Type":1,"Title":"周度简报(weekly update)","MatchCount":null},{"CategoryId":1429,"ArticleId":0,"Summary":null,"Type":1,"Title":"SIN","MatchCount":null}],"RelatedArticles":null}],"MoreResults":true,"PageSize":20,"Page":1,"SearchText":null,"RecordCount":923},"AvailableYears":[2017,2018,2019,2020,2021,2022,2023,2024,2025,2026]},"IsDefaultSelectedTab":false,"TabId":43},{"Name":"US Policy","SortOrder":6,"Template":2,"ShouldAutoPopulate":true,"ShouldAutoPopulateAsync":false,"Content":{"NewsDisplayCategories":[{"Name":"US Policy","ParentCategoryId":1004,"SortOrder":0,"IsContentFilterCategory":false,"DataValue":null,"CategoryId":1487}],"NewsFilterCategories":[{"CategoryId":1487}],"Config":{"ShouldApplyStickyFilter":false},"Articles":{"Metadata":{"Year":null,"Search":null,"ShouldApplyStickyOnlyFilter":false},"Results":[{"ArticleId":221374,"Title":"US Supreme Court Ruling on US Tariffs - 22nd February 2026","Content":"","Synopsis":"After the US Supreme Court stuck down most tariffs implemented last year, the US President has announced a new temporary import tariff of 15% on all trade partners under a separate legal framework.","KeyWords":null,"LastUpdated":"0001-01-01T00:00:00","PublishedOn":"2026-02-22T00:00:00","UseContentForSynopsis":false,"Authors":[{"Name":"Clarksons Research"}],"Url":"https://sin.clarksons.net/News/Article/221374","RoleRestrictionsJson":"{\"DefaultRestriction\": \"Show\"}","DocumentLinkRoleRestrictionsJson":"{\"DefaultRestriction\": \"Show\"}","IsSticky":false,"HasContent":true,"ArticleTemplateId":null,"RequiresTrialistOrSubscriberAccess":true,"IsPublished":0,"ArticleEntityLinks":[{"CategoryId":1486,"ArticleId":0,"Summary":null,"Type":1,"Title":"Policy","MatchCount":null},{"CategoryId":12,"ArticleId":0,"Summary":null,"Type":1,"Title":"Shipping Related","MatchCount":null},{"CategoryId":1042,"ArticleId":0,"Summary":null,"Type":1,"Title":"Briefings","MatchCount":null},{"CategoryId":1412,"ArticleId":0,"Summary":null,"Type":1,"Title":"United States","MatchCount":null},{"CategoryId":1429,"ArticleId":0,"Summary":null,"Type":1,"Title":"SIN","MatchCount":null}],"RelatedArticles":null},{"ArticleId":221140,"Title":"US Maritime Action Plan: Summary of Proposals - 15th February 2026","Content":"","Synopsis":"On 13th Feb, the US Government published its ‘Maritime Action Plan’, providing more detail on planned policy actions to revitalise the US maritime industry. Potential policies include fees for foreign-built vessels carrying imports into the US, investment in US shipyards and the broader maritime supply chain, maritime workforce training and the creation of a US flagged strategic commercial fleet.","KeyWords":null,"LastUpdated":"0001-01-01T00:00:00","PublishedOn":"2026-02-15T00:00:00","UseContentForSynopsis":false,"Authors":[{"Name":"Clarksons Research"}],"Url":"https://sin.clarksons.net/News/Article/221140","RoleRestrictionsJson":"{\"DefaultRestriction\": \"Show\"}","DocumentLinkRoleRestrictionsJson":"{\"DefaultRestriction\": \"Show\"}","IsSticky":false,"HasContent":true,"ArticleTemplateId":null,"RequiresTrialistOrSubscriberAccess":true,"IsPublished":0,"ArticleEntityLinks":[{"CategoryId":12,"ArticleId":0,"Summary":null,"Type":1,"Title":"Shipping Related","MatchCount":null},{"CategoryId":1486,"ArticleId":0,"Summary":null,"Type":