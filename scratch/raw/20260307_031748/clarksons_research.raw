,"ArticleId":221067,"Summary":"(SIN) Freq: A, Unit: % Yr/Yr (tonnes)","Type":6,"Title":"World Seaborne LNG Trade","MatchCount":null},{"TsSeriesId":98804,"TimeseriesSortOrder":7,"ArticleId":221067,"Summary":"(SIN) Freq: A, Unit: Million Tonnes","Type":6,"Title":"World Seaborne LNG Trade","MatchCount":null}],"RelatedArticles":null},{"ArticleId":220861,"Title":"Sanctioned Vessel &amp; Oil Trade Flows Overview: February 2026","Content":"","Synopsis":"Following further expansion of US sanctions against Iran, the count of tankers specifically listed as sanctioned has increased to 934 oil tankers and 112m dwt, 16% of global tanker fleet capacity, with recent impacts of sanctions and geo-politics on oil trade flows increasing “mainstream” tanker demand.","KeyWords":null,"LastUpdated":"0001-01-01T00:00:00","PublishedOn":"2026-02-09T00:00:00","UseContentForSynopsis":false,"Authors":[{"Name":"Stephen Gordon"}],"Url":"https://sin.clarksons.net/News/Article/220861","RoleRestrictionsJson":"{\"DefaultRestriction\": \"Show\"}","DocumentLinkRoleRestrictionsJson":"{\"DefaultRestriction\": \"Show\"}","IsSticky":false,"HasContent":true,"ArticleTemplateId":null,"RequiresTrialistOrSubscriberAccess":true,"IsPublished":0,"ArticleEntityLinks":[{"CategoryId":617,"ArticleId":0,"Summary":null,"Type":1,"Title":"Tanker","MatchCount":null},{"CategoryId":1042,"ArticleId":0,"Summary":null,"Type":1,"Title":"Briefings","MatchCount":null},{"CategoryId":1429,"ArticleId":0,"Summary":null,"Type":1,"Title":"SIN","MatchCount":null},{"CategoryId":1430,"ArticleId":220861,"Summary":null,"Type":1,"Title":"WFR","MatchCount":null},{"CategoryId":833,"ArticleId":220861,"Summary":null,"Type":1,"Title":"World Fleet Monitor","MatchCount":null},{"ArticleImageLinkId":0,"Description":null,"Height":null,"Width":null,"Location":"/News/GetImage?Type=Thumbnail&FileName=EmployeePhotos%2F18376.jpg","RecordAdded":null,"Usage":"Thumbnail","ArticleId":0,"Summary":null,"Type":3,"Title":null,"MatchCount":null},{"TsSeriesId":121106