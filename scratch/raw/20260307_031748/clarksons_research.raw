esSortOrder":18,"ArticleId":221441,"Summary":"(SIN) Freq: A, Unit: % Yr/Yr","Type":6,"Title":"Far East - Europe Container Trade Growth y-o-y","MatchCount":null},{"TsSeriesId":534029,"TimeseriesSortOrder":17,"ArticleId":221441,"Summary":"(SIN) Freq: A, Unit: % Yr/Yr","Type":6,"Title":"Transpacific Eastbound Container Trade Growth y-o-y","MatchCount":null},{"TsSeriesId":534434,"TimeseriesSortOrder":2,"ArticleId":221441,"Summary":"(SIN) Freq: A, Unit: % Yr/Yr (TEU)","Type":6,"Title":"World Seaborne Container Trade","MatchCount":null},{"TsSeriesId":534442,"TimeseriesSortOrder":21,"ArticleId":221441,"Summary":"(SIN) Freq: M, Unit: %","Type":6,"Title":"Containership Orderbook % Fleet","MatchCount":null},{"TsSeriesId":534501,"TimeseriesSortOrder":4,"ArticleId":221441,"Summary":"(SIN) Freq: A, Unit: % Yr/Yr","Type":6,"Title":"Containership Fleet Growth","MatchCount":null},{"TsSeriesId":542041,"TimeseriesSortOrder":1,"ArticleId":221441,"Summary":"(SIN) Freq: W, Unit: Index","Type":6,"Title":"Containership Timecharter Rate Index","MatchCount":null},{"TsSeriesId":546905,"TimeseriesSortOrder":8,"ArticleId":221441,"Summary":"(SIN) Freq: D, Unit: Million TEU","Type":6,"Title":"Port Congestion Index - Containerships In Port, m.TEU, 7dma","MatchCount":null},{"TsSeriesId":547470,"TimeseriesSortOrder":16,"ArticleId":221441,"Summary":"(SIN) Freq: A, Unit: Million TEU","Type":6,"Title":"Transpacific Eastbound Container Trade","MatchCount":null},{"TsSeriesId":548622,"TimeseriesSortOrder":3,"ArticleId":221441,"Summary":"(SIN) Freq: A, Unit: % Yr/Yr (TEU-miles)","Type":6,"Title":"World Seaborne Container Trade","MatchCount":null},{"TsSeriesId":552761,"TimeseriesSortOrder":5,"ArticleId":221441,"Summary":"(SIN) Freq: D, Unit: Number","Type":6,"Title":"Containerships Re-Routing Away From Red Sea/Gulf of Aden","MatchCount":null},{"TsSeriesId":556624,"TimeseriesSortOrder":15,"ArticleId":221441,"Summary":"(SIN) Freq: D, Unit: TEU, China-US Boxship Tracker – 6-17k TEU Ships Departing Asia EB, 14dma","Type":6,"Title":"China-US Containership Tracker – 6-17k TEU Ships Departing Asia Eastbound Across Pacific, 14dma","MatchCount":null},{"TsSeriesId":556629,"TimeseriesSortOrder":7,"ArticleId":221441,"Summary":"(SIN) Freq: D, Unit: % Yr/Yr, China-US Boxship Tracker – 6-17k TEU Ships Departing Asia EB, 14dma","Type":6,"Title":"China-US Containership Tracker – 6-17k TEU Ships Departing Asia Eastbound Across Pacific, 14dma","MatchCount":null},{"TsSeriesId":8852030,"TimeseriesSortOrder":22,"ArticleId":221441,"Summary":"(SIN, WFR) Freq: M, Unit: Knots","Type":6,"Title":"Containership Average Speed","MatchCount":null},{"TsSeriesId":551620,"TimeseriesSortOrder":23,"ArticleId":221441,"Summary":"(SIN) Freq: D, Unit: TEU","Type":6,"Title":"Total Containership Gulf of Aden Vessel Arrivals","MatchCount":null}],"RelatedArticles":null},{"ArticleId":221377,"Title":"Sizing Up Containership Operators’ Ownership Swing","Content":"","Synopsis":"The exceptional container markets of recent years have given liner companies an opportunity to drive a major wave of growth in the fleet and build an increasingly dominant ownership position in the sector. With operators now owning twice as much tonnage as charter owners, we take a look at the drivers of this shift and the potential implications ahead…","KeyWords":null,"LastUpdated":"0001-01-01T00:00:00","PublishedOn":"2026-02-20T00:00:00","UseContentForSynopsis":false,"Authors":[{"Name":"David Whittaker"}],"Url":"https://sin.clarksons.net/News/Article/221377","RoleRestrictionsJson":"{\"DefaultRestriction\": \"Show\"}","DocumentLinkRoleRestrictionsJson":"{\"DefaultRestriction\": \"Show\"}","IsSticky":false,"HasContent":true,"ArticleTemplateId":null,"RequiresTrialistOrSubscriberAccess":true,"IsPublished":0,"ArticleEntityLinks":[{"CategoryId":627,"ArticleId":221377,"Summary":null,"Type":1,"Title":"Containership","MatchCount":null},{"CategoryId":845,"ArticleId":221377,"Summary":null,"Type":1,"Title":"Shipping Intelligence Weekly","MatchCount":null},{"CategoryId":1041,"ArticleId":221377,"Summary":null,"Type":1,"Title":"Analysis","MatchCount":null},{"ArticleImageLinkId":44929,"Description":"David Whittaker","Height":null,"Width":null,"Location":"/News/GetImage?Type=Thumbnail&FileName=EmployeePhotos%2F114552.jpg","RecordAdded":"2026-02-23T09:07:20","Usage":"Thumbnail","ArticleId":221377,"Summary":null,"Type":3,"Title":null,"MatchCount":null},{"ArticleImageLinkId":44930,"Description":"Backpage Image","Height":null,"Width":null,"Location":"/News/GetImage?Type=Image&FileName=Articles%2F221377%2F2026-02-23_upload_9114552_SIW%201712.png","RecordAdded":"2026-02-23T09:07:20","Usage":"Main Image","ArticleId":221377,"Summary":null,"Type":3,"Title":null,"MatchCount":null},{"TsSeriesId":530258,"TimeseriesSortOrder":1,"ArticleId":221377,"Summary":"(SIN) Freq: M, Unit: TEU thousand, Total Container Operator Owner Flt Dev","Type":6,"Title":"Total Containership Operator Owner Fleet Development","MatchCount":null},{"TsSeriesId":530252,"TimeseriesSortOrder":2,"ArticleId":221377,"Summary":"(SIN) Freq: M, Unit: TEU thousand, Total Container Charter Owner Flt Dev","Type":6,"Title":"Total Containership Charter Owner Fleet Development","MatchCount":null},{"TsSeriesId":530399,"TimeseriesSortOrder":3,"ArticleId":221377,"Summary":"(SIN) Freq: M, Unit: TEU thousand","Type":6,"Title":"Containership Charter Owner Orderbook","MatchCount":null},{"TsSeriesId":530409,"TimeseriesSortOrder":4,"ArticleId":221377,"Summary":"(SIN) Freq: M, Unit: TEU thousand","Type":6,"Title":"Containership Operator Owner Orderbook","MatchCount":null},{"TsSeriesId":542041,"TimeseriesSortOrder":5,"ArticleId":221377,"Summary":"(SIN) Freq: W, Unit: Index","Type":6,"Title":"Containership Timecharter Rate Index","MatchCount":null}],"RelatedArticles":null},{"ArticleId":221294,"Title":"Shipbuilding Focus: Japan","Content":"","Synopsis":"Japan is the third largest builder country globally, accounting for 12% of deliveries in 2025 in CGT. While Japan is still a world leader in constructing high-quality bulkers, it has lost shipbuilding market share in recent decades amidst tough competition from China and South Korea. Here we review the current position of Japanese yards and the country’s stated ambition to strengthen its industry.","KeyWords":null,"LastUpdated":"0001-01-01T00:00:00","PublishedOn":"2026-02-20T12:31:39","UseContentForSynopsis":false,"Authors":[{"Name":"Charlotte Leach"}],"Url":"https://sin.clarksons.net/News/Article/221294","RoleRestrictionsJson":"{\"DefaultRestriction\": \"Show\"}","DocumentLinkRoleRestrictionsJson":"{\"DefaultRestriction\": \"Show\"}","IsSticky":false,"HasContent":true,"ArticleTemplateId":null,"RequiresTrialistOrSubscriberAccess":true,"IsPublished":0,"ArticleEntityLinks":[{"CategoryId":834,"ArticleId":221294,"Summary":null,"Type":1,"Title":"World Shipyard Monitor","MatchCount":null},{"CategoryId":1041,"ArticleId":221294,"Summary":null,"Type":1,"Title":"Analysis","MatchCount":null},{"ArticleImageLinkId":44890,"Description":"Charlotte Leach","Height":null,"Width":null,"Location":"/News/GetImage?Type=Thumbnail&FileName=EmployeePhotos%2F174541.jpg","RecordAdded":"2026-02-20T12:31:39","Usage":"Thumbnail","ArticleId":221294,"Summary":null,"Type":3,"Title":null,"MatchCount":null},{"ArticleImageLinkId":44891,"Description":"Backpage Image","Height":null,"Width":null,"Location":"/News/GetImage?Type=Image&FileName=Articles%2F221294%2F2026-02-20_upload_2129393_WSMT_2026_02.png","RecordAdded":"2026-02-20T12:31:39","Usage":"Main Image","ArticleId":221294,"Summary":null,"Type":3,"Title":null,"MatchCount":null}],"RelatedArticles":null},{"ArticleId":221252,"Title":"Bulkcarrier Market Outlook - February 2026","Content":"","Synopsis":"Bulkcarrier markets have had a relatively positive start to 2026, with earnings easing seasonally as expected but remaining positive by historical standards, with average sector earnings averaging ~$14,000/day in January, rising to ~$16,000/day by mid-Feb","KeyWords":null,"LastUpdated":"0001-01-01T00:00:00","PublishedOn":"2026-02-18T00:00:00","UseContentForSynopsis":false,"Authors":[{"Name":"Clarksons Research"}],"Url":"https://sin.clarksons.net/News/Article/221252","RoleRestrictionsJson":"{\"DefaultRestriction\": \"Show\"}","DocumentLinkRoleRestrictionsJson":"{\"DefaultRestriction\": \"Show\"}","IsSticky":false,"HasContent":true,"ArticleTemplateId":null,"RequiresTrialistOrSubscriberAccess":true,"IsPublished":0,"ArticleEntityLinks":[{"CategoryId":625,"ArticleId":221252,"Summary":null,"Type":1,"Title":"Bulker","MatchCount":null},{"CategoryId":1041,"ArticleId":221252,"Summary":null,"Type":1,"Title":"Analysis","MatchCount":null},{"CategoryId":1429,"ArticleId":221252,"Summary":null,"Type":1,"Title":"SIN","MatchCount":null},{"CategoryId":1463,"ArticleId":221252,"Summary":null,"Type":1,"Title":"Sector Outlook","MatchCount":null},{"TsSeriesId":19236,"TimeseriesSortOrder":22,"ArticleId":221252,"Summary":"(SIN) Freq: M, Unit: Million Tonnes","Type":6,"Title":"Brazil Seaborne Iron Ore Exports","MatchCount":null},{"TsSeriesId":30234,"TimeseriesSortOrder":18,"ArticleId":221252,"Summary":"(SIN, SV) Freq: M, Unit: DWT million","Type":6,"Title":"Total Bulkcarrier Demolition","MatchCount":null},{"TsSeriesId":33152,"TimeseriesSortOrder":21,"ArticleId":221252,"Summary":"(SIN) Freq: M, Unit: DWT","Type":6,"Title":"Total Bulker Sales","MatchCount":null},{"TsSeriesId":97730,"TimeseriesSortOrder":1,"ArticleId":221252,"Summary":"(SIN, WFR) Freq: M, Unit: $/day","Type":6,"Title":"Clarksons Average Bulker Earnings","MatchCount":null},{"TsSeriesId":534431,"TimeseriesSortOrder":3,"ArticleId":221252,"Summary":"(SIN) Freq: A, Unit: % Yr/Yr (tonnes)","Type":6,"Title":"World Seaborne Dry Bulk Trade","MatchCount":null},{"TsSeriesId":534435,"TimeseriesSortOrder":2,"ArticleId":221252,"Summary":"(SIN) Freq: M, Unit: % Yr/Yr","Type":6,"Title":"Bulkcarrier Fleet Growth","MatchCount":null},{"TsSeriesId":534436,"TimeseriesSortOrder":14,"ArticleId":221252,"Summary":"(SIN) Freq: M, Uni