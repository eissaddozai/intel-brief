<div request-verification-token=_6RaeHr8PKSAzi8YHabMa5I7vKy2OFjlsJ-Kntn4tCJ1Lw1h_GQXdgCGmnbCLZGf0uVu7UW7neDYNLAXnoGco316jzc1:4ZJDXS_lCgItmPaA0VUiWnphnqn3y0CGzzNbTrjw2yrwe75l676mDOqHUlO5Pdd4o_wvkNdW9CuJGqisAfKC39r1Lf01 ng-cloak class="container-fluid height100OverrideMobile home-col-{{Home.DisplayLayoutColumns}} home-type-{{Home.Name | lowercase}} custom-home" id="HomePage" ng-controller="HomeController">
        <ul class="nav nav-pills visible-xs" id="mobileTargetNav">
            <li ng-repeat="pod in Home.Pods | orderBy:'SortOrder'" ng-if="pod.TemplateType != '6'">
                <a ng-if="pod.DisplayName" ng-attr-href="#{{pod.DisplayName | slugName}}" ng-class="{active: $first}">{{pod.DisplayName}}</a>
            </li>
        </ul>

    <div class="row height100OverrideMobile" ng-init="colWidth = (12 % Home.DisplayLayoutColumns == 0) ? (12/Home.DisplayLayoutColumns) : 4">
            <div ng-repeat="pod in Home.Pods | orderBy:'SortOrder'" 
                 pod="pod" 
                 ng-class="(pod.DisplayFullHeight) ? 'height100OverrideMobile' : 'height50OverrideMobile'" 
                 ng-attr-id="{{pod.DisplayName | slugName}}" 
                 ng-attr-class="{{(pod.Name != 'Graph') ? 'third custom col-sm-5' : 'third custom col-sm-2 pull-right'}}">
            </div>
    </div>
</div>

<script type="text/ng-template" id="PodDirectiveTemplate">
    <div ng-class="(pod.Tabs.length === 1 && pod.TemplateType !== 8) ? 'no-tabs' : 'full-tabs'" ng-attr-class="{{(pod.TemplateType === 6) ? 'search-container height100OverrideMobile charts' : (pod.TemplateType == 9) ? 'height100OverrideMobile' : 'search-container height100OverrideMobile'}}">
        <h3 class="brand-title" ng-switch on="pod.TemplateType" ng-if="pod.TemplateType != '6' && pod.TemplateType != '9'">
            <i class="fa fa-newspaper-o" aria-hidden="true" ng-switch-when="1"></i>
            <i class="fa fa-search" aria-hidden="true" ng-switch-when="2"></i>
            <i class="fa fa-globe" aria-hidden="true" ng-switch-when="3"></i>
            <i class="fa fa-link" aria-hidden="true" ng-switch-when="4"></i>
            <i class="fa fa-search" aria-hidden="true" ng-switch-when="5"></i>
            <i class="fa fa-line-chart" aria-hidden="true" ng-switch-when="7"></i>
            <i class="fa fa-bar-chart" aria-hidden="true" ng-switch-when="8"></i>
            <i class="fa fa-bar-chart" aria-hidden="true" ng-switch-when="10"></i>
            <i class="fa fa-newspaper-o" aria-hidden="true" ng-switch-when="11"></i>
            <i class="fa fa-filter" aria-hidden="true" ng-switch-when="12"></i>
            {{pod.DisplayName}}
        </h3>
        <ul class="nav nav-tabs no-wrap" role="tablist" ng-if="pod.Tabs.length > 1 && shouldShowTabs">
            <li class="clickable no-wrap" role="presentation" ng-repeat="tab in pod.Tabs | orderBy: 'SortOrder'" ng-class="{active:historyState.SelectedTabId == tab.TabId}" ng-click="setTab(tab)">
                <a aria-controls="{{tab.TabId}}" role="tab">{{tab.Name}}</a>
            </li>
        </ul>
        <div  class="height100OverrideMobile clearfix">
            
            <div class="tab-content height100OverrideMobile"  ng-if="pod.TemplateType==1">
                


<div class="search-panel tab-pane height100OverrideMobile" ng-repeat="tab in pod.Tabs | orderBy: 'SortOrder'" role="tabpanel" id="{{tab.TabId}}" ng-class="{active:tab.TabId == historyState.SelectedTabId}">
    <div ng-controller="TabsNewsController" class="search-panel-pod height100OverrideMobile">
        <div class="flex-container wrap">
            <div class="flex-item" ng-if="tab.Content.AvailableYears">
                <span kendo-drop-down-list="yearsDropDownList" k-options="yearsDropDownListOptions" class="full-width homepage-dropdown" k-rebind="historyState.Year" k-ng-model="historyState.Year">

                </span>

            </div>
            <div class="flex-item" ng-if="tab.Content.NewsDisplayCategories">
                <span kendo-drop-down-list="articleCategoriesDropDownList" k-options="articleCategoriesDropDownListOptions" k-ng-model="historyState.Category" class="homepage-dropdown full-width" k-rebind="pod.State.SelectedTabId">

                </span>
            </div>
            <div class="flex-item">
                <div class="input-group">
                    <div class="search-text">
                        <input name="search" class="form-control" placeholder="Search {{tab.Name}}" type="text" ng-model="historyState.SearchText" enter-key-press="ensureLoggedInGetSearchResults(tab.Content.Articles, historyState, false)" />
                    </div>

                    <span class="input-group-btn">
                        <button ng-click="ensureLoggedInGetSearchResults(tab.Content.Articles, historyState); searchAgain=false" class="btn-md btn-default btn-primary btn">Go <span class="glyphicon glyphicon-menu-right hidden-sm hidden-xs" aria-hidden="true"></span></button>
                    </span>
                </div>
            </div>

        </div>


        <div class="search-results height100OverrideMobile">
            <div ng-show="!tab.Content.Articles.requestProcessing && !tab.Content.Articles.Results.length" style="padding: 20px; display: block;" class="text-center">
                <h4>
                    <i class="fa fa-exclamation-circle" aria-hidden="true"></i> No results <span ng-show="historyState.ActiveSearchText">for "{{historyState.ActiveSearchText}}"</span> under <u>{{tab.Name}} <span ng-show="historyState.Category.Name">>></span> {{historyState.Category.Name}} <span ng-show="historyState.Year.Value">for year</span> {{historyState.Year.Value}}</u>.
                </h4>
                <button ng-click="reset()" class="btn-sm btn-default btn-primary btn">Reset</button>
            </div>

            <div ng-switch="tab.Template">
                <div class="tab-content height100OverrideMobile" ng-switch-default>
                    <div style="border-bottom: 1px dashed rgb(153, 153, 153); margin-bottom: 10px;">
    <div class="news-article" ng-repeat="article in tab.Content.Articles.Results track by article.ArticleId">
        <div class="container-fluid news-article-contianer">
	<div class="title-container">
		<div class="image-placeholder" ng-repeat="imageLink in article.ArticleEntityLinks | filter: {Usage: 'Thumbnail'}"  ng-if="imageLink.Location.length > 0">			
			<img class="thumbnail-image" ng-attr-src="{{imageLink.Location}}" ng-attr-title="{{imageLink.Description}}" />			
		</div>
		<div class="article-info">
			<span class="news-category show-sin-oin" ng-repeat="links in article.ArticleEntityLinks" 
			      ng-if="isDisplayedCategoryTitle(links.Title)">
				<i class="fa" 
				   ng-class="getDisplayedCategoryIcon(links.Title)"
				   aria-hidden="true"></i>
				<span>{{links.Title}} </span>
			</span>
            <div class="publish-info show-sin-oin">
                <span class="time" ng-if="article.PublishedOn">
                    <i class="fa fa-calendar" aria-hidden="true"></i>{{ article.PublishedOn | crslDateTime:"dd Z yyyy" }}
                </span>
                <span ng-repeat="author in article.Authors" class="author">
                    <i class="fa fa-pencil-square-o" aria-hidden="true"></i>
                    {{author.Name}}<span ng-show="$index == (article.Authors.length - 2)"> and </span>
                    <span ng-show="$index != (article.Authors.length - 1) && $index != (article.Authors.length - 2)">, </span>
                </span>
            </div>
            <a class="news-article-title block clickable" 
			   ng-href="{{article.Url}}#{{homePageTypeS}}" 
			   ng-click="openLinksPage(article, $event)" 
			   bind-html-compile model="article.Title" 
			   ng-if="!onlyOneDocumentLinkAndNoContent(article) && !article.RequiresTrialistOrSubscriberAccess"></a>
			<a class="news-article-title block clickable" 
			   ng-href="{{article.Url}}#{{homePageTypeS}}" 
			   ensure-login-click="openLinksPage(article, $event)" 
			   bind-html-compile model="article.Title" 
			   ng-if="!onlyOneDocumentLinkAndNoContent(article) && article.RequiresTrialistOrSubscriberAccess"></a>
			<a class="news-article-title block clickable" 
			   ensure-login-click="openArticleDocumentDownloadModal(article)" 
			   bind-html-compile model="article.Title" 
			   ng-if="onlyOneDocumentLinkAndNoContent(article)"></a>
			<div class="publish-info show-wfr-wor">
				<span class="time">
					{{ article.PublishedOn | crslDateTime:"dd Z yyyy" }}
				</span> 
                <span ng-if="article.Authors && article.Authors.length > 0"> by
                    <span ng-repeat="author in article.Authors" class="author">
                        {{author.Name}}<span ng-show="$index == (article.Authors.length - 2)"> and </span>
                        <span ng-show="$index != (article.Authors.length - 1) && $index != (article.Authors.length - 2)">, </span>
                    </span>
                </span>
			</div>
			<div ng-show="article.Synopsis" bind-html-compile model="article.Synopsis" class="synopsis"></div>
			
		</div>
	</div>
</div>
    </div>
</div>

                </div>

                <div class="tab-content height100OverrideMobile" ng-switch-when="2">
                    <div class="latest-feature" ng-repeat="article in tab.Content.Articles.Results track by article.ArticleId" ng-if="$first">
    <div class="container-fluid text-justify">
        <span class="pull-right">
            <img class="featured-news-image" ng-repeat="imageLink in article.ArticleEntityLinks | filter: {Usage: 'Thumbnail'}" ng-attr-src="{{imageLink.Location}}" ng-attr-title="{{imageLink.Description}}" />
        </span>
        <span class="news-category show-sin-oin" ng-repeat="links in article.ArticleEntityLinks" 
              ng-if="isDisplayedCategoryTitle(links.Title)">
            <i class="fa" 
               ng-class="getDisplayedCategoryIcon(links.Title)"
               aria-hidden="true"></i>
            <span>{{links.Title}} </span>
        </span>
        <div class="feature-publish-info show-sin-oin">
            <i ng-if="article.PublishedOn" class="fa fa-calendar" aria-hidden="true"></i> 
            <span ng-if="article.PublishedOn" class="date-text">{{ article.PublishedOn | crslDateTime:"dd Z yy" }}</span> 
            <i ng-if="article.Authors && article.Authors.length > 0" class="fa fa-pencil-square-o" aria-hidden="true"></i> 
            <span ng-repeat="author in article.Authors">
                {{author.Name}}<span ng-show="$index == (article.Authors.length - 2)"> and </span><span ng-show="$index != (article.Authors.length - 1) && $index != (article.Authors.length - 2)">, </span>
            </span>
        </div>
        <h4>
            <a class="clickable" ng-href="{{article.Url}}#{{homePageTypeS}}" ng-click="openLinksPage(article)" bind-html-compile model="article.Title" ng-if="!onlyOneDocumentLinkAndNoContent(article) && !article.RequiresTrialistOrSubscriberAccess"></a>
            <a class="clickable" ng-href="{{article.Url}}#{{homePageTypeS}}" ensure-login-click="openLinksPage(article)" bind-html-compile model="article.Title" ng-if="!onlyOneDocumentLinkAndNoContent(article) && article.RequiresTrialistOrSubscriberAccess"></a>
            <a class="clickable" ensure-login-click="openArticleDocumentDownloadModal(article)" bind-html-compile model="article.Title" ng-if="onlyOneDocumentLinkAndNoContent(article)"></a>
        </h4>
        <div class="feature-publish-info show-wfr-wor">
            <span class="date-text">{{ article.PublishedOn | crslDateTime:"dd Z yy" }}</span><span ng-if="article.Authors && article.Authors.length > 0"> by 
                <span ng-repeat="author in article.Authors">
                    {{author.Name}}<span ng-show="$index == (article.Authors.length - 2)"> and </span><span ng-show="$index != (article.Authors.length - 1) && $index != (article.Authors.length - 2)">, </span>
                </span>
            </span>
        </div>
        <div>
            <div bind-html-compile model="article.Synopsis"></div>
            <a ng-if="article.Url" ng-href="{{ article.Url }}">Read full story...</a>
        </div>
    </div>
</div>
<div style="border-bottom: 1px dashed rgb(153, 153, 153); margin-bottom: 10px;">
    <div class="news-article" ng-repeat="article in tab.Content.Articles.Results track by article.ArticleId" ng-if="!$first">
        <div class="container-fluid news-article-contianer">
	<div class="title-container">
		<div class="image-placeholder" ng-repeat="imageLink in article.ArticleEntityLinks | filter: {Usage: 'Thumbnail'}"  ng-if="imageLink.Location.length > 0">			
			<img class="thumbnail-image" ng-attr-src="{{imageLink.Location}}" ng-attr-title="{{imageLink.Description}}" />			
		</div>
		<div class="article-info">
			<span class="news-category show-sin-oin" ng-repeat="links in article.ArticleEntityLinks" 
			      ng-if="isDisplayedCategoryTitle(links.Title)">
				<i class="fa" 
				   ng-class="getDisplayedCategoryIcon(links.Title)"
				   aria-hidden="true"></i>
				<span>{{links.Title}} </span>
			</span>
            <div class="publish-info show-sin-oin">
                <span class="time" ng-if="article.PublishedOn">
                    <i class="fa fa-calendar" aria-hidden="true"></i>{{ article.PublishedOn | crslDateTime:"dd Z yyyy" }}
                </span>
                <span ng-repeat="author in article.Authors" class="author">
                    <i class="fa fa-pencil-square-o" aria-hidden="true"></i>
                    {{author.Name}}<span ng-show="$index == (article.Authors.length - 2)"> and </span>
                    <span ng-show="$index != (article.Authors.length - 1) && $index != (article.Authors.length - 2)">, </span>
                </span>
            </div>
            <a class="news-article-title block clickable" 
			   ng-href="{{article.Url}}#{{homePageTypeS}}" 
			   ng-click="openLinksPage(article, $event)" 
			   bind-html-compile model="article.Title" 
			   ng-if="!onlyOneDocumentLinkAndNoContent(article) && !article.RequiresTrialistOrSubscriberAccess"></a>
			<a class="news-article-title block clickable" 
			   ng-href="{{article.Url}}#{{homePageTypeS}}" 
			   ensure-login-click="openLinksPage(article, $event)" 
			   bind-html-compile model="article.Title" 
			   ng-if="!onlyOneDocumentLinkAndNoContent(article) && article.RequiresTrialistOrSubscriberAccess"></a>
			<a class="news-article-title block clickable" 
			   ensure-login-click="openArticleDocumentDownloadModal(article)" 
			   bind-html-compile model="article.Title" 
			   ng-if="onlyOneDocumentLinkAndNoContent(article)"></a>
			<div class="publish-info show-wfr-wor">
				<span class="time">
					{{ article.PublishedOn | crslDateTime:"dd Z yyyy" }}
				</span> 
                <span ng-if="article.Authors && article.Authors.length > 0"> by
                    <span ng-repeat="author in article.Authors" class="author">
                        {{author.Name}}<span ng-show="$index == (article.Authors.length - 2)"> and </span>
                        <span ng-show="$index != (article.Authors.length - 1) && $index != (article.Authors.length - 2)">, </span>
                    </span>
                </span>
			</div>
			<div ng-show="article.Synopsis" bind-html-compile model="article.Synopsis" class="synopsis"></div>
			
		</div>
	</div>
</div>
    </div>
</div>

                </div>

                <div class="tab-content height100OverrideMobile" ng-switch-when="7">
                    <ul class="results">
    <li ng-repeat="article in tab.Content.Articles.Results track by article.ArticleId">
        <div class="news-article-title-dark">
            <a ensure-login-click="downloadPdf(article)" class="clickable">{{article.Title}}</a>
        </div>
        <div class="block">
            {{ article.PublishedOn | crslDateTime:"dd Z yy" }}

            by
            <span ng-repeat="author in article.Authors">
                <b>{{author.Name}}</b><span ng-show="$index == (article.Authors.length - 2)"> and </span><span ng-show="$index != (article.Authors.length - 1) && $index != (article.Authors.length - 2)">, </span>
            </span>
        </div>
    </li>
</ul>
                </div>

                <div class="tab-content height100OverrideMobile" ng-switch-when="15">
                    <div class="news-article-compact-container">
    <div class="news-article news-article-compact" ng-repeat="article in tab.Content.Articles.Results track by article.ArticleId">
        
        <div class="news-article-compact-title">
        
            <div>
                <a class="article-title-link"
                   ng-href="{{article.Url}}#{{homePageTypeS}}"
                   ensure-login-click="openLinksPage(article, $event)"
                   bind-html-compile model="article.Title"
                   ng-if="!onlyOneDocumentLinkAndNoContent(article) && article.RequiresTrialistOrSubscriberAccess"></a>
                
                <a class="article-title-link"
                    ensure-login-click="openArticleDocumentDownloadModal(article)"
                    bind-html-compile model="article.Title"
                    ng-if="onlyOneDocumentLinkAndNoContent(article)"></a>
            </div>

            <div class="time publish-info text-nowrap" ng-if="article.PublishedOn">
                <i class="fa fa-calendar" aria-hidden="true"></i>{{ article.PublishedOn | crslDateTime:"dd Z yy" }}
            </div>

        </div>
        
        <div class="article-synopsis" ng-show="article.Synopsis" bind-html-compile model="article.Synopsis"></div>

    </div>
</div>

                </div>

            </div>
            <div class="more-register-search-results">
                <div ng-show="tab.Content.Articles.requestProcessing" style="padding: 6px;">
                    <i class="fa fa-refresh fa-spin fa-fw text-success"></i>
                    <span class="sr-only">Loading...</span>
                </div>
                <button class="btn-xs btn-primary btn" ng-show="!tab.Content.Articles.requestProcessing && tab.Content.Articles.MoreResults" ng-disabled="getSearchResultsLocked" ng-click="ensureLoggedInGetSearchResults(tab.Content.Articles, historyState, true)">More</button>

            </div>
        </div>
        <div class="results-total clearfix" ng-show="!searchAgain && !tab.Content.Articles.requestProcessing && tab.Content.Articles.Results.length">
            
            <span>1 - {{(tab.Content.Articles.PageSize * tab.Content.Articles.Page) > tab.Content.Articles.RecordCount ? tab.Content.Articles.RecordCount : (tab.Content.Articles.PageSize * tab.Content.Articles.Page)}} of {{tab.Content.Articles.RecordCount.toLocaleString()}}</span>
        </div>
    </div>

</div>

            </div>
            <div class="tab-content height100OverrideMobile"  ng-if="pod.TemplateType==2">
                
<div class="search-panel tab-pane height100OverrideMobile register-template" ng-repeat="tab in pod.Tabs | orderBy: 'SortOrder'" role="tabpanel" id="{{tab.TabId}}" ng-class="{active:tab.TabId == historyState.SelectedTabId}">
    <div register-search="tab" parent-pod="pod" class="height100OverrideMobile search-panel-pod"></div>
</div>
            </div>
            <div class="tab-content height100OverrideMobile"  ng-if="pod.TemplateType==3">
                <div class="search-results tab-pane" id="map-block" ng-repeat="tab in pod.Tabs | orderBy: 'SortOrder'" role="tabpanel" ng-id="{{tab.TabId}}" ng-class="{active:tab.TabId == historyState.SelectedTabId}" bind-html-compile model="tab.Content.Article.Content">
</div>
            </div>
            <div class="tab-content height100OverrideMobile" ng-if="pod.TemplateType==4">
                <div class="search-panel tab-pane height100OverrideMobile register-template" ng-repeat="tab in pod.Tabs | orderBy: 'SortOrder'" role="tabpanel" id="{{tab.TabId}}" ng-class="{active:tab.TabId == historyState.SelectedTabId}">
    <div class="height100OverrideMobile search-panel-pod" ng-controller="TabsRegisterLinksController">

        <div class="search-text">
            <input name="search" class="form-control" placeholder="Search {{tab.Name}}" type="text" ng-model="historyState.SearchText.Title" />
        </div>

        <div class="search-results height100OverrideMobile" ng-init="search = tab.Content.Links">

            <div class="tab-content">
                <ul class="results text-left">
                    <li ng-repeat="result in filteredResults = (search.Results | filter:historyState.SearchText)">    
						<a class="clickable" ng-if="result.Url" ensure-login-click="openLinksPage(result)" bind-html-compile model="result.Title"></a>
						<a class="clickable" ng-if="!result.Url" data-toggle="tooltip" data-placement="top" title="You do not have access to this content, please contact us for more details"  bind-html-compile model="result.Title"></a>
                    </li>
                </ul>
                <div ng-show="!filteredResults.length" style="padding: 20px; display: block;" class="text-center">
                    <h4>
                        <i class="fa fa-exclamation-circle" aria-hidden="true"></i> No results <span ng-show="historyState.SearchText.Title">for "{{historyState.SearchText.Title}}"</span>.
                    </h4>
                    <button ng-click="historyState.SearchText = ''" class="btn-sm btn-default btn-primary btn">Reset</button>
                </div>
            </div>
        </div>
        <div class="results-total clearfix" ng-show="filteredResults.length">
            <span>1 - {{filteredResults.length}} of {{search.RecordCount.toLocaleString()}}</span>
        </div>

    </div>

</div>
            </div>
            <div class="tab-content height100OverrideMobile"  ng-if="pod.TemplateType==5">
                

<div class="search-panel tab-pane register-template active" ng-repeat="tab in pod.Tabs | orderBy: 'SortOrder'" role="tabpanel" id="{{tab.TabId}}">
    <div register-search="tab" parent-pod="pod"></div>
</div>
            </div>
            <div class="tab-content height100OverrideMobile"  ng-if="pod.TemplateType==6">
                


<div ng-controller="TabsTimeseriesChartsController" class="height100OverrideMobile" id="chartPlaceholder">
	<div ng-repeat="timeseries in TsSeriesIdsToDisplay track by timeseries" class="col-md-12 col-sm-6 clearfix">
		<div timeseries-small-chart init-data=" { tsSeriesId: timeseries, isHomePage: true }"></div>
	</div>
</div>



            </div>

            <div class="tab-content height100OverrideMobile"  ng-if="pod.TemplateType==7">
                


<div class="search-panel tab-pane height100OverrideMobile" ng-repeat="tab in pod.Tabs | orderBy: 'SortOrder'" role="tabpanel" id="{{tab.TabId}}" ng-class="{active:tab.TabId == historyState.SelectedTabId}">
    <div ng-if="tab.Template === 11" ng-controller="TabsNewsController" class="height100OverrideMobile">
        <div class="search-results height100OverrideMobile table-grid">
            <div ng-show="!tab.Content.Articles.requestProcessing && !tab.Content.Articles.Results.length" style="padding: 20px; display: block;" class="text-center">
                <h4>
                    <i class="fa fa-exclamation-circle" aria-hidden="true"></i> No results <span ng-show="historyState.ActiveSearchText">for "{{historyState.ActiveSearchText}}"</span> under <u>{{tab.Name}} <span ng-show="historyState.Category.Name">>></span> {{historyState.Category.Name}} <span ng-show="historyState.Year.Value">for year</span> {{historyState.Year.Value}}</u>.
                </h4>
                <button ng-click="reset()" class="btn-sm btn-default btn-primary btn">Reset</button>
            </div>
            <div ng-show="tab.Content.Articles.Results.length">
                <div class="grid-header">
	<table class="table no-margin table-condensed table-bordered">
		<thead>
			<tr>
				<th>Type</th>
				<th>Title</th>
				<th width="84px">Updated</th>
				<th>&nbsp;</th>
			</tr>
		</thead>
	</table>
</div>
<div class="grid-body">
	<table class="table no-margin table-condensed table-bordered">
		<tbody>
			<tr class="news-article" ng-repeat="article in tab.Content.Articles.Results track by article.ArticleId" ng-click="notifyTimeseriesChartsControllerOfChange(article.ArticleEntityLinks)">
				<td class="bold">{{article.MarketsDisplayCategory.Title}}</td>
				<td>
					<span bind-html-compile model="article.Title"></span>
				</td>
				<td>{{ article.PublishedOn | crslDateTime:"dd Z yyyy" }}</td>
				<td class="button-link text-center"><a class="btn btn-xs btn-primary" ng-click="$event.stopPropagation()" ng-attr-href="{{article.Url}}#{{homePageTypeS}}?catId={{article.MarketsDisplayCategory.CategoryId}}&catName={{encodeURIComponent(article.MarketsDisplayCategory.Title)}}">View</a></td>
			</tr>
		</tbody>
	</table>
	<div class="more-register-search-results">
		<div ng-show="tab.Content.Articles.requestProcessing">
			<i class="fa fa-refresh fa-spin fa-fw text-success"></i>
			<span class="sr-only">Loading...</span>
		</div>
		<button class="btn-xs btn-primary btn" ng-show="!tab.Content.Articles.requestProcessing && tab.Content.Articles.MoreResults" ng-disabled="getSearchResultsLocked" ng-click="getSearchResults(tab.Content.Articles, historyState, true, true)">More</button>
	</div>
</div>
                
            </div>
        </div>
        <div class="results-total clearfix" ng-show="!searchAgain && !tab.Content.Articles.requestProcessing && tab.Content.Articles.Results.length">
            
            <span>1 - {{(tab.Content.Articles.PageSize * tab.Content.Articles.Page) > tab.Content.Articles.RecordCount ? tab.Content.Articles.RecordCount : (tab.Content.Articles.PageSize * tab.Content.Articles.Page)}} of {{tab.Content.Articles.RecordCount.toLocaleString()}}</span>
        </div>
    </div>

    <div ng-if="tab.Template === 10" class="height100OverrideMobile" ng-controller="HomeCtrl">
        <div ng-controller="MarketsAtAGlanceHomeCtrl" class="height100OverrideMobile">
            <div class="height100OverrideMobile MarketGlanceGrid" kendo-grid="MarketGlanceGrid" k-options="gridOptions">
</div>

<script id="exportHeaderTemplate" type="text/x-kendo-template">
    <button type="button" class="btn grid-button" ng-click="bulkExportGridData()">Export Bundle</button>
</script>

<script id="exportCellTemplate" type="text/x-kendo-template">
    <div ng-show="sparkLineDataExistsForMarket(#= data.ts_series_id#)" title="Click to view the chart" ensure-login-click="openTimeSeriesModal(#= data.ts_series_id#, true)" id="lineChart#= data.ts_series_id#" class="marketGlanceLineChart clickable">
    </div>   
	<span class="spark-line-timeperiod">#= (data.default_frequency == 'A') ? '12Y' : (data.default_frequency == 'Q') ? '4Y' : (data.default_frequency == 'M') ? '12M' : '12W'#</span>
    <button type="button" class="btn grid-button" ensure-login-click="openTimeSeriesModal(#= data.ts_series_id#, true)">Chart</button>
    <button type="button" class="btn grid-button" ensure-login-click="openTimeSeriesModal(#= data.ts_series_id#)">Grid</button>
</script>

        </div>
    </div>

</div>

            </div>

            <div class="tab-content height100OverrideMobile"  ng-if="pod.TemplateType==9">
                


<div class="search-panel tab-pane height100OverrideMobile" ng-repeat="tab in pod.Tabs | orderBy: 'SortOrder'" role="tabpanel" id="{{tab.TabId}}" ng-class="{active:tab.TabId == historyState.SelectedTabId}">
    <div ng-controller="TabsNewsController" class="height100OverrideMobile">
        <ul class="breadcrumb hidden-print">
            <li><a href="/"><i class="fa fa-home" aria-hidden="true"></i></a></li>
            <li class="hidden-xs" ng-show="breadcrumbCategoryName"><a href="#" bind-html-compile model="breadcrumbCategoryName"></a></li>
        </ul>
        <div class="flex-container wrap">
            <div class="flex-item" ng-if="tab.Content.AvailableYears">
                <span kendo-drop-down-list="yearsDropDownList" k-options="yearsDropDownListOptions" class="full-width" k-rebind="historyState.Year" k-ng-model="historyState.Year">

                </span>

            </div>
            <div class="flex-item">
                <div class="input-group">
                    <div class="search-text">
                        <input name="search" class="form-control" placeholder="Search {{tab.Name}}" type="text" ng-model="historyState.SearchText" enter-key-press="getSearchResults(tab.Content.Articles, historyState, false)"/>
                    </div>

                    <span class="input-group-btn">
                        <button ng-click="getSearchResults(tab.Content.Articles, historyState); searchAgain=false" class="btn-md btn-default btn-primary btn">Go <span class="glyphicon glyphicon-menu-right hidden-sm hidden-xs" aria-hidden="true"></span></button>
                    </span>
                </div>
            </div>

        </div>


        <div class="search-results height100OverrideMobile">
            <div class="more-register-search-results">
                <div ng-show="tab.Content.Articles.requestProcessing" style="padding: 6px;">
                    <i class="fa fa-refresh fa-spin fa-fw text-success"></i>
                    <span class="sr-only">Loading...</span>
                </div>


            </div>
            <div ng-show="!tab.Content.Articles.requestProcessing && !tab.Content.Articles.Results.length" style="padding: 20px; display: block;" class="text-center">
                <h4>
                    <i class="fa fa-exclamation-circle" aria-hidden="true"></i> No results <span ng-show="historyState.ActiveSearchText">for "{{historyState.ActiveSearchText}}"</span> under <u>{{tab.Name}} <span ng-show="historyState.Category.Name">>></span> {{historyState.Category.Name}} <span ng-show="historyState.Year.Value">for year</span> {{historyState.Year.Value}}</u>.
                </h4>
                <button ng-click="reset()" class="btn-sm btn-default btn-primary btn">Reset</button>
            </div>


            <div class="tab-content height100OverrideMobile">
                <div style="border-bottom: 1px dashed rgb(153, 153, 153); margin-bottom: 10px;">
    <div class="news-article" ng-repeat="article in tab.Content.Articles.Results track by article.ArticleId">
        <div class="container-fluid">
			<div class="container-fluid news-article-contianer">
	<div class="title-container">
		<div class="image-placeholder" ng-repeat="imageLink in article.ArticleEntityLinks | filter: {Usage: 'Thumbnail'}"  ng-if="imageLink.Location.length > 0">			
			<img class="thumbnail-image" ng-attr-src="{{imageLink.Location}}" ng-attr-title="{{imageLink.Description}}" />			
		</div>
		<div class="article-info">
			<span class="news-category show-sin-oin" ng-repeat="links in article.ArticleEntityLinks" 
			      ng-if="isDisplayedCategoryTitle(links.Title)">
				<i class="fa" 
				   ng-class="getDisplayedCategoryIcon(links.Title)"
				   aria-hidden="true"></i>
				<span>{{links.Title}} </span>
			</span>
            <div class="publish-info show-sin-oin">
                <span class="time" ng-if="article.PublishedOn">
                    <i class="fa fa-calendar" aria-hidden="true"></i>{{ article.PublishedOn | crslDateTime:"dd Z yyyy" }}
                </span>
                <span ng-repeat="author in article.Authors" class="author">
                    <i class="fa fa-pencil-square-o" aria-hidden="true"></i>
                    {{author.Name}}<span ng-show="$index == (article.Authors.length - 2)"> and </span>
                    <span ng-show="$index != (article.Authors.length - 1) && $index != (article.Authors.length - 2)">, </span>
                </span>
            </div>
            <a class="news-article-title block clickable" 
			   ng-href="{{article.Url}}#{{homePageTypeS}}" 
			   ng-click="openLinksPage(article, $event)" 
			   bind-html-compile model="article.Title" 
			   ng-if="!onlyOneDocumentLinkAndNoContent(article) && !article.RequiresTrialistOrSubscriberAccess"></a>
			<a class="news-article-title block clickable" 
			   ng-href="{{article.Url}}#{{homePageTypeS}}" 
			   ensure-login-click="openLinksPage(article, $event)" 
			   bind-html-compile model="article.Title" 
			   ng-if="!onlyOneDocumentLinkAndNoContent(article) && article.RequiresTrialistOrSubscriberAccess"></a>
			<a class="news-article-title block clickable" 
			   ensure-login-click="openArticleDocumentDownloadModal(article)" 
			   bind-html-compile model="article.Title" 
			   ng-if="onlyOneDocumentLinkAndNoContent(article)"></a>
			<div class="publish-info show-wfr-wor">
				<span class="time">
					{{ article.PublishedOn | crslDateTime:"dd Z yyyy" }}
				</span> 
                <span ng-if="article.Authors && article.Authors.length > 0"> by
                    <span ng-repeat="author in article.Authors" class="author">
                        {{author.Name}}<span ng-show="$index == (article.Authors.length - 2)"> and </span>
                        <span ng-show="$index != (article.Authors.length - 1) && $index != (article.Authors.length - 2)">, </span>
                    </span>
                </span>
			</div>
			<div ng-show="article.Synopsis" bind-html-compile model="article.Synopsis" class="synopsis"></div>
			
		</div>
	</div>
</div>
        </div>
    </div>
</div>

            </div>


        </div>
        <div class="results-total clearfix row" ng-show="!searchAgain && !tab.Content.Articles.requestProcessing && tab.Content.Articles.Results.length">
            <ul class="pagination pull-left no-margin text-left col-xs-8 col-md-10 col-lg-11">
                <li>
                    <button ng-click="getSearchResults(tab.Content.Articles, historyState, (tab.Content.Articles.Page - 1))" ng-disabled="tab.Content.Articles.Page === 1 || getSearchResultsLocked" class="btn btn-xs btn-primary fa fa-chevron-left" title="Previous Page"></button>
                </li>
                <li ng-repeat="_ in ((_ = []) && (_.length=(tab.Content.Articles.RecordCount/tab.Content.Articles.PageSize | numberCeilFilter)) && _) track by $index+1" class="hidden-sm hidden-xs">
                    <button class="btn btn-xs btn-default" ng-click="getSearchResults(tab.Content.Articles, historyState, ($index + 1))" ng-class="{active:tab.Content.Articles.Page === $index+1}" ng-disabled="tab.Content.Articles.Page === $index+1" title="Page {{$index+1}}">{{$index+1}}</button>
                </li>
                <li class="visible-sm visible-xs inline-block">Page {{tab.Content.Articles.Page}} of {{tab.Content.Articles.RecordCount/tab.Content.Articles.PageSize | numberCeilFilter}} </li>
                <li ng-class="{disabled:!tab.Content.Articles.MoreResults || getSearchResultsLocked}">
                    <button ng-click="getSearchResults(tab.Content.Articles, historyState, (tab.Content.Articles.Page + 1))" ng-disabled="!tab.Content.Articles.MoreResults || getSearchResultsLocked" class="btn btn-xs btn-primary fa fa-chevron-right" title="Next Page"></button>
                </li>
            </ul>
            
            <span>{{(tab.Content.Articles.Page === 1) ? 1 : (tab.Content.Articles.PageSize * (tab.Content.Articles.Page - 1)) + 1}} - {{(tab.Content.Articles.PageSize * tab.Content.Articles.Page) > tab.Content.Articles.RecordCount ? tab.Content.Articles.RecordCount : (tab.Content.Articles.PageSize * tab.Content.Articles.Page)}} of {{tab.Content.Articles.RecordCount.toLocaleString()}}</span>
        </div>
    </div>

</div>

            </div>

            <div class="tab-content height100OverrideMobile"  ng-if="pod.TemplateType==10">
                <div class="chart-panel tab-pane height100OverrideMobile" ng-repeat="tab in pod.Tabs | orderBy: 'SortOrder'" role="tabpanel" id="{{tab.TabId}}" ng-class="{active:tab.TabId == historyState.SelectedTabId}">                
    <div ng-controller="TabsDashboardChartController" class="height100OverrideMobile">        
        <div timeseries-small-chart init-data="{ hideTitle: true, alwaysShowLegend: true, tsSeriesId: tab.Content.refreshAvailableTimeseries.TimeseriesIdList[0], showMultiple: true, chartType: tab.Content.refreshAvailableTimeseries.ChartType, chartStack: tab.Content.refreshAvailableTimeseries.IsChartStack }"></div>        
    </div>
</div>   
            </div>

            <div class="tab-content height100OverrideMobile"  ng-if="pod.TemplateType==12">
                <div class="filter-panel tab-pane height100OverrideMobile" ng-repeat="tab in pod.Tabs | orderBy: 'SortOrder'" role="tabpanel" id="{{tab.TabId}}" ng-class="{active:tab.TabId == historyState.SelectedTabId}">    
    <div ng-controller="TabsDashboardCriteriaController">       
		<button  type="button" class="btn btn-danger btn-sm" ng-click="reset()">Reset</button>   
        <div ng-init="fields = tab.Content.DashboardCriteriaFields | orderBy: 'SortOrder'">
            <div ng-repeat="dashboardCriteriaField in fields" 
                 ng-init="dashboardCriteriaField.columnTotal = fields[$index-1].columnTotal + (dashboardCriteriaField.SelectorId ? 12 : 6)" ng-class="(dashboardCriteriaField.SelectorId) ? 'full-width' : 'half-width'" class="filter-wrapper ">                
				
                    <div class="panel" ng-class="(dashboardCriteriaField.hasData) ? 'panel-default' : 'panel-danger'">
                        <div class="panel-heading">
                            {{dashboardCriteriaField.DisplayName}}
                        </div>
                        <div class="panel-body">
                            <div ng-if="dashboardCriteriaField.SelectorId">
                                <div kendo-tree-view="dashboardCriteriaField.treeViewSelector"
                                     k-data-source="dashboardCriteriaField.treeViewSelectorData"
                                     k-options="treeViewSelectorOptions">
                                </div>
                            </div>
                            <div ng-if="dashboardCriteriaField.DataFieldId">
                                <div kendo-tree-view="dashboardCriteriaField.treeViewDataField"
                                     k-data-source="dashboardCriteriaField.treeViewDataFieldData"
                                     k-options="treeViewDataFieldOptions">
                                </div>
                            </div>
                            <div ng-hide="dashboardCriteriaField.hasData">
                                There is no data available for {{dashboardCriteriaField.DisplayName}} based on your current selections.
                            </div>
                        </div>
                    </div>     
            </div>
        </div>       
    </div>
</div>
            </div>

            <div class="height100OverrideMobile"  ng-if="pod.TemplateType==8" ng-controller="HomeCtrl">
                <!-- required to show only home level tabs-->
                 <div ng-controller="MarketsAtAGlanceCtrl" class="height100OverrideMobile">
	<ul class="nav nav-tabs" ng-repeat="node in activeTreePath" ng-show="node.children.length > 0" ng-class="{'menu-alt': activeTreePath.indexOf(node)%2 == 1}">
		<li ng-repeat="item in node.children" ng-class="{true:'active', false:''}[activeTreePath.indexOf(item) > -1]"><a class="pointer" ng-click="activeItemChange(item);">{{item.name}}</a></li>
	</ul>
	<div class="search-panel height100OverrideMobile">
		<div class="height100OverrideMobile MarketGlanceGrid" kendo-grid="MarketGlanceGrid" k-options="gridOptions">
</div>

<script id="exportHeaderTemplate" type="text/x-kendo-template">
    <button type="button" class="btn grid-button" ng-click="bulkExportGridData()">Export Bundle</button>
</script>

<script id="exportCellTemplate" type="text/x-kendo-template">
    <div ng-show="sparkLineDataExistsForMarket(#= data.ts_series_id#)" title="Click to view the chart" ensure-login-click="openTimeSeriesModal(#= data.ts_series_id#, true)" id="lineChart#= data.ts_series_id#" class="marketGlanceLineChart clickable">
    </div>   
	<span class="spark-line-timeperiod">#= (data.default_frequency == 'A') ? '12Y' : (data.default_frequency == 'Q') ? '4Y' : (data.default_frequency == 'M') ? '12M' : '12W'#</span>
    <button type="button" class="btn grid-button" ensure-login-click="openTimeSeriesModal(#= data.ts_series_id#, true)">Chart</button>
    <button type="button" class="btn grid-button" ensure-login-click="openTimeSeriesModal(#= data.ts_series_id#)">Grid</button>
</script>

	 </div>
 </div>
            </div>

        </div>
    </div>

</script>
<script type="text/ng-template" id="RegisterSearchDirectiveTemplate">
    

    <div class="input-group">
        <div class="search-text">
            <input name="search" class="form-control" placeholder="Search {{tab.Name}}" type="text" ng-model="historyState.SearchText" enter-key-press="ensureLoggedInGetSearchResults(search, historyState, false)" />
        </div>

        <span class="input-group-btn">
            <button ng-click="ensureLoggedInGetSearchResults(search, historyState, false);" class="btn-md btn-default btn-primary btn">Go <span class="glyphicon glyphicon-menu-right hidden-sm hidden-xs" aria-hidden="true"></span></button>
        </span>
    </div>



<div class="search-results height100OverrideMobile">
    <div ng-show="historyState.ActiveSearchText && !search.requestProcessing && !search.RecordCount" style="padding: 20px; display: block;" class="text-center">
        <h4>
            <i class="fa fa-exclamation-circle" aria-hidden="true"></i> No results <span ng-show="historyState.ActiveSearchText">for "{{historyState.ActiveSearchText}}"</span>.
        </h4>
        <button ng-click="reset()" class="btn-sm btn-default btn-primary btn">Reset</button>
    </div>

    <div class="tab-content">
        <ul class="results text-left" ng-repeat="resultGrouping in search.Results">
            <li ng-repeat="result in resultGrouping" class="register-search-result">
                    <a class="register-search-result-link" ng-href="{{result.Url}}">{{result.Title}}</a>
                <div class="sub-title">{{result.SubTitle}}</div>
            </li>
        </ul>
    </div>


    <div class="more-register-search-results" ng-show="!search.requestProcessing">
        <div ng-show="search.requestProcessing" style="padding: 6px;">
            <i class="fa fa-refresh fa-spin fa-fw text-success"></i>
            <span class="sr-only">Loading...</span>
        </div>
        <button class="btn-xs btn-primary btn" ng-show="!search.requestProcessing && search.MoreResults" ng-disabled="getSearchResultsLocked" ng-click="ensureLoggedInGetSearchResults(search, historyState, true)">More</button>

    </div>

</div>
<div class="results-total clearfix" ng-show="search.RecordCount && !searchAgain && search && !search.requestProcessing">
    
    <span>1 - {{(search.PageSize * search.Page) > search.RecordCount ? search.RecordCount : (search.PageSize * search.Page)}} of {{search.RecordCount.toLocaleString()}}</span>
</div>

</script>

<link href='/Styles/HomeBundle.css?v=hWmqn6zbrDdUpWIJUp9VFdM_vOwkzzIcW6YnHoSWxDA1?v=639084092759509449' rel='stylesheet'/>
<link href='/Styles/NewsBundle.css?v=baE5D9568DzcU_2ZlQrZ0Yv0n2_W8nqOPo0EfCYTu5g1?v=639084092759509449' rel='stylesheet'/>
<link href='/Styles/RegisterSearchCategoriesBundle.css?v=Z_9KukdIVRrB7YInNYXnEYuhmHs1TSsu4gtIiJVCeKo1?v=639084092759509449' rel='stylesheet'/>


                <a name="anchorBottom"></a>
            </div>
        
    <footer>
        <div id="bottom" class="footer navbar navbar-inverse navbar-fixed-bottom">
            <div class="container-fluid">
                <div id="footer-body">
                    
<ul class="list-inline pull-right" id="footer-links">
            <li><a href="/Navigation?website=FRONTEND&amp;path=portal/contact-us">Contact Us</a></li>
            <li><a href="/Navigation?website=PORTAL&amp;path=terms">Terms of Use</a></li>
            <li><a href="/Navigation?website=FRONTEND&amp;path=portal/disclaimer">Disclaimer</a></li>
        <li><a href="/Navigation?website=FRONTEND&amp;path=portal/privacy-policy">Privacy Policy</a></li>
        <li><a href="/Navigation?website=FRONTEND&amp;path=portal/cookie-policy">Cookie Policy</a></li>
        <li><a href="/Navigation?website=FRONTEND&amp;path=portal/security-statement">Security Statement</a></li>
        <li><a target="_blank" href="https://twitter.com/clarksons_crsl"><i class="fa-brands fa-x-twitter fa-2x" aria-hidden="true"></i></a></li>
        <li><a target="_blank" href="https://linkedin.com/company/clarksons-research"><i class="fa-brands fa-linkedin-in fa-2x" aria-hidden="true"></i></a></li>
        <li>
            <a target="_blank" href="/Navigation?website=PORTAL&amp;path=Seanet%3FtargetPath%3Dmap%26returnWebsite%3DSIN">Seanet</a>
        </li>
            <li><a target="_blank" href="/Navigation?website=OIN&amp;path="><span>OIN</span></a></li>
            <li><a target="_blank" href="/Navigation?website=WFR&amp;path="><span>WFR</span></a></li>
            <li><a target="_blank" href="/Navigation?website=WOR&amp;path="><span>WOR</span></a></li>
            <li><a target="_blank" href="/Navigation?website=RIN&amp;path="><span>RIN</span></a></li>
            <li><a target="_blank" href="http://www.clarksons.com">Clarksons Group</a></li>

</ul>

                    <div class="footer-float-left">
                            <a href="/Navigation?website=PORTAL&amp;path=" target="_blank">
                                <img src="/Content/Images/Clarksons_Research_logo_White.svg" / class="footer-brand-image">
                            </a>
                        

                    </div>

                </div>
            </div>
                <a id="buttonTop" class="visible-xs"><i class="fa fa-arrow-up" aria-hidden="true"></i></a>
        </div>
    </footer>

    

    

    
    

    <script type="text/ng-template" id="ErrorPopup">
        <div class="modal-header">
            <h3 class="modal-title">Sorry, we encountered an error.</h3>
        </div>
        <div class="modal-body" style="min-height:300px;font-size: 1.3em;">
            <p>
                {{ ErrorMessage }}
            </p>
            <p>
                If you would like to get in contact with our support team, please email <a href="mailto:development.crs@clarksons.co.uk">development.crs@clarksons.co.uk</a>.
            </p>
        </div>
        <div class="modal-footer">
            <button class="btn btn-primary" ng-click="close()">Close</button>
        </div>
    </script>

    <script type="text/ng-template" id="HttpErrorPopup">
        <div class="modal-header">
            <h3 class="modal-title">Sorry, we encountered {{ data.length > 1 ? "some errors" : "an error" }}.</h3>
        </div>
        <div class="modal-body" style="min-height:300px;font-size: 1.3em;">
            <ul style="list-style:none; padding: 0">
                <li ng-repeat="errorGuid in data">
                    <p>
                        If you would like to get in contact with our support team, please email <a href="mailto:development.crs@clarksons.co.uk">development.crs@clarksons.co.uk</a> including the following reference number:
                        {{ errorGuid }}
                    </p>
                    <hr ng-if="data.length > 1 && $index < data.length - 1" />
                </li>
            </ul>
        </div>
        <div class="modal-footer">
            <button class="btn btn-primary" ng-click="close()">Close</button>
        </div>
    </script>

    <script type="text/ng-template" id="CloudTokenExceptionPopup">
        <div class="modal-header">
            <img src="/Content/Images/Clarksons_Research_logo_Blue.svg" style="width:300px;padding: 10px;" />
            <img src="/Content/Images/SeaNetLogo.png" class="img-responsive" />
        </div>
        <div class="modal-body" style="min-height:300px;font-size: 1.3em;">
            <p><b>{{ errorMessage }}</b></p>
            <p>
                If you would like to add a subscription or take a trial to Clarksons Sea/net please contact our sales team at <a href="mailto:sales.crs@clarksons.com">sales.crs@clarksons.com</a> or call +44 (0)20 7334 3134.
            </p>
            <p>
                If you would like to contact our technical support team, please email <a href="mailto:development.crs@clarksons.co.uk">development.crs@clarksons.co.uk</a>
                with the following reference number: <b>{{ errorGuid }}</b>
            </p>
        </div>
        <div class="modal-footer">
            <button class="btn btn-primary" ng-click="close()">Close</button>
        </div>
    </script>

    <script type="text/javascript">

        $(document)
            .ready(function () {

                $('[data-toggle=searchbox]')
                    .click(function () {
                        $('#search-container').toggleClass('collapse');
                    });

                $("#mobileTargetNav a")
                    .click(function (e) {
                        e.preventDefault();
                        var section = $(this).attr("href");
                        $('html, body')
                            .animate({
                                scrollTop: $(section).offset().top - 160
                            },
                                1000);
                        $("#mobileTargetNav a").removeClass('active');
                        $(this).addClass('active');
                    });
                $("#navbar [data-toggle=dropdown]")
                    .click(function (e) {
                        $(this).parents('li').toggleClass('open');
                        e.preventDefault();

                    });
            });


    </script>

</div>

    <script src="/Scripts/commons.bundle.js?v=2.0.359.0"></script>


<script src="/Scripts/Home.bundle.js?v=2.0.359.0"></script>
<script src="https://www.clarksons.net/portal/Scripts/CookieBannerApp.bundle.js"></script>
<script src="https://www.clarksons.net/portal/Scripts/MarketingPreferencesPopupApp.bundle.js"></script>

</body>
</html>

