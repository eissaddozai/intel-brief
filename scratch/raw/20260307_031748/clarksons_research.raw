Id":0,"Summary":"(SIN) Freq: W, Unit: DWT million, Total Crude Tanker Strait of Hormuz Transits","Type":6,"Title":"Strait of Hormuz Transits > Crude Tanker","MatchCount":null},{"TsSeriesId":557270,"TimeseriesSortOrder":13,"ArticleId":0,"Summary":"(SIN, WFR) Freq: D, Unit: % Fleet (DWT), Sanctioned Fleet Development > Aframax 85-124,999 dwt, Sanctioned Crude Aframax Tanker Fleet Development","Type":6,"Title":"Sanctioned Fleet Development > Crude Tankers > Aframax 85-124,999 dwt","MatchCount":null},{"ArticleDocumentLinkId":null,"ArticleDocumentId":967,"ArticleDocumentGuid":"e48b52a0-5b0e-4c79-9f03-77131d0323c1","Location":"Sanctioned Vessel And Oil Trade Flows Overview February 2026.pdf","CreatedDate":null,"DeleteStatus":false,"ArticleId":220861,"Summary":null,"Type":8,"Title":"Sanctioned Vessel And Oil Trade Flows Overview February 2026.pdf","MatchCount":null}],"RelatedArticles":null},{"ArticleId":220673,"Title":"Indonesia Coal Exports Update (4th Feb 2026)","Content":"","Synopsis":"Some Indonesian coal miners have reportedly stopped offering spot cargoes in the seaborne coal market amid uncertainty around 2026 production quotas","KeyWords":null,"LastUpdated":"0001-01-01T00:00:00","PublishedOn":"2026-02-04T00:00:00","UseContentForSynopsis":false,"Authors":[{"Name":"Clarksons Research"}],"Url":"https://sin.clarksons.net/News/Article/220673","RoleRestrictionsJson":"{\"DefaultRestriction\": \"Show\"}","DocumentLinkRoleRestrictionsJson":"{\"DefaultRestriction\": \"Show\"}","IsSticky":false,"HasContent":true,"ArticleTemplateId":null,"RequiresTrialistOrSubscriberAccess":true,"IsPublished":0,"ArticleEntityLinks":[{"CategoryId":1042,"ArticleId":0,"Summary":null,"Type":1,"Title":"Briefings","MatchCount":null},{"CategoryId":1429,"ArticleId":0,"Summary":null,"Type":1,"Title":"SIN","MatchCount":null},{"CategoryId":625,"ArticleId":220673,"Summary":null,"Type":1,"Title":"Bulker","MatchCount":null},{"TsSeriesId":541964,"TimeseriesSortOrder":1,"ArticleId":0,"Summary":"(SIN) Freq: A, Unit: Million Tonnes","Type":6,"Title":"Indonesia Seaborne Coal Exports","MatchCount":null}],"RelatedArticles":null},{"ArticleId":220669,"Title":"Red Sea Disruption: Market Impact Tracker - February 2026","Content":"","Synopsis":"The prospect of increases in Red Sea transits has again been in focus in recent weeks, with some liner companies announcing the restart of some services through the Suez Canal. However, following a small-scale increase in traffic in late 2025, Red Sea transits have remained broadly stable in recent weeks, still significantly down from ‘typical’ levels.","KeyWords":null,"LastUpdated":"0001-01-01T00:00:00","PublishedOn":"2026-02-04T00:00:00","UseContentForSynopsis":false,"Authors":[{"Name":"Stephen Gordon"}],"Url":"https://sin.clarksons.net/News/Article/220669","RoleRestrictionsJson":"{\"DefaultRestriction\": \"Show\"}","DocumentLinkRoleRestrictionsJson":"{\"DefaultRestriction\": \"Show\"}","IsSticky":false,"HasContent":true,"ArticleTemplateId":null,"RequiresTrialistOrSubscriberAccess":true,"IsPublished":0,"ArticleEntityLinks":[{"CategoryId":1042,"ArticleId":0,"Summary":null,"Type":1,"Title":"Briefings","MatchCount":null},{"CategoryId":1429,"ArticleId":0,"Summary":null,"Type":1,"Title":"SIN","MatchCount":null},{"ArticleImageLinkId":0,"Description":null,"Height":null,"Width":null,"Location":"/News/GetImage?Type=Thumbnail&FileName=EmployeePhotos%2F18376.jpg","RecordAdded":null,"Usage":"Thumbnail","ArticleId":220669,"Summary":null,"Type":3,"Title":null,"MatchCount":null},{"TsSeriesId":551390,"TimeseriesSortOrder":1,"ArticleId":220669,"Summary":"(SIN) Freq: D, Unit: GT million","Type":6,"Title":"Total Gulf of Aden Vessel Arrivals","MatchCount":null},{"TsSeriesId":551620,"TimeseriesSortOrder":2,"ArticleId":220669,"Summary":"(SIN) Freq: D, Unit: TEU","Type":6,"Title":"Total Containership Gulf of Aden Vessel Arrivals","MatchCount":null},{"TsSeriesId":552761,"TimeseriesSortOrder":3,"ArticleId":220669,"Summary":"(SIN) Freq: D, Unit: Number","Type":6,"Title":"Containerships Re-Routing Away From Red Sea/Gulf of Aden","MatchCount":null},{"TsSeriesId":551511,"TimeseriesSortOrder":4,"ArticleId":220669,"Summary":"(SIN) Freq: W, Unit: DWT million","Type":6,"Title":"Total Crude Tanker Gulf of Aden Vessel Arrivals","MatchCount":null},{"TsSeriesId":551530,"TimeseriesSortOrder":5,"ArticleId":220669,"Summary":"(SIN) Freq: D, Unit: DWT million","Type":6,"Title":"Total Bulkcarrier Gulf of Aden Vessel Arrivals","MatchCount":null},{"TsSeriesId":551625,"TimeseriesSortOrder":6,"ArticleId":220669,"Summary":"(SIN) Freq: D, Unit: Vehicles","Type":6,"Title":"Total Pure Car Carrier Gulf of Aden Vessel Arrivals","MatchCount":null},{"TsSeriesId":551615,"TimeseriesSortOrder":7,"ArticleId":220669,"Summary":"(SIN) Freq: D, Unit: Cu. M.","Type":6,"Title":"Total LNG Gulf of Aden Vessel Arrivals","MatchCount":null},{"ArticleDocumentLinkId":null,"ArticleDocumentId":965,"ArticleDocumentGuid":"5382a1c2-32b3-4d10-b47a-4c1aa7dc747e","Location":"Red Sea Tracker February 2026.pdf","CreatedDate":null,"DeleteStatus":false,"ArticleId":220669,"Summary":null,"Type":8,"Title":"Red Sea Tracker February 2026.pdf","MatchCount":null}],"RelatedArticles":null},{"ArticleId":220661,"Title":"US-India Trade Agreement Update (3rd Feb 2026)","Content":"","Synopsis":"The US and India have announced a trade deal, with the US due to cut import tariffs on Indian goods from a ‘headline’ 50% to 18%, while the US has also claimed that India will cut purchases of Russian crude oil.","KeyWords":null,"LastUpdated":"0001-01-01T00:00:00","PublishedOn":"2026-02-03T00:00:00","UseContentForSynopsis":false,"Authors":[{"Name":"Stephen Gordon"}],"Url":"https://sin.clarksons.net/News/Article/220661","RoleRestrictionsJson":"{\"DefaultRestriction\": \"Show\"}","DocumentLinkRoleRestrictionsJson":"{\"DefaultRestriction\": \"Show\"}","IsSticky":false,"HasContent":true,"ArticleTemplateId":null,"RequiresTrialistOrSubscriberAccess":true,"IsPublished":0,"ArticleEntityLinks":[{"CategoryId":1042,"ArticleId":0,"Summary":null,"Type":1,"Title":"Briefings","MatchCount":null},{"CategoryId":1429,"ArticleId":0,"Summary":null,"Type":1,"Title":"SIN","MatchCount":null},{"CategoryId":12,"ArticleId":220661,"Summary":null,"Type":1,"Title":"Shipping Related","MatchCount":null},{"CategoryId":1486,"ArticleId":220661,"Summary":null,"Type":1,"Title":"Policy","MatchCount":null},{"CategoryId":1412,"ArticleId":220661,"Summary":null,"Type":1,"Title":"United States","MatchCount":null},{"ArticleImageLinkId":0,"Description":null,"Height":null,"Width":null,"Location":"/News/GetImage?Type=Thumbnail&FileName=EmployeePhotos%2F18376.jpg","RecordAdded":null,"Usage":"Thumbnail","ArticleId":220661,"Summary":null,"Type":3,"Title":null,"MatchCount":null},{"TsSeriesId":12110694,"TimeseriesSortOrder":1,"ArticleId":0,"Summary":"(SIN, WFR) Freq: D, Unit: No., Sanctioned Oil Tanker Fleet Development","Type":6,"Title":"Sanctioned Fleet Development > Oil Tankers","MatchCount":null}],"RelatedArticles":null},{"ArticleId":220145,"Title":"Monthly Offshore Renewables Highlights - January 2026","Content":"","Synopsis":"Offshore wind capacity grew by 10% across 2025 despite the sector facing significant headwinds which resulted in a meaningful slowdown in CAPEX commitments ($39bn committed, down 10% y-o-y). ‘Wind’ vessel utilisation and charter rates remained healthy throughout 2025, though the newbuilding sector was sluggish with ordering volumes down -58% overall from 2024.","KeyWords":null,"LastUpdated":"0001-01-01T00:00:00","PublishedOn":"2026-01-20T00:00:00","UseContentForSynopsis":false,"Authors":[{"Name":"Clarksons Research"}],"Url":"https://sin.clarksons.net/News/Article/220145","RoleRestrictionsJson":"{\"DefaultRestriction\": \"Show\"}","DocumentLinkRoleRestrictionsJson":"{\"DefaultRestriction\": \"Show\"}","IsSticky":false,"HasContent":true,"ArticleTemplateId":null,"RequiresTrialistOrSubscriberAccess":true,"IsPublished":0,"ArticleEntityLinks":[{"CategoryId":1450,"ArticleId":0,"Summary":null,"Ty