    <div class="container fixed hidden top-20 lg:top-24 left-1/2 -translate-x-1/2 z-40 opacity-0 duration-500 transition-opacity max-h-[calc(100dvh-8rem)] overflow-y-auto overscroll-none lg:rounded-lg lg:shadow-lg lg:bg-white" id="searchBar">
    <div class="px-3 pb-3 pt-0 rounded-lg lg:rounded-none shadow-lg lg:shadow-none bg-white mx-1">
        <div class="flex bg-white items-center w-full h-full sticky top-0 pt-3">
            <div class="p-2">
                &nbsp;<i class="fa-light fa-magnifying-glass fa-xl text-opec"></i>&nbsp;
            </div>
            <div class="p-2 grow">
                <input type="text" id="searchInput" maxlength="128" class="w-full rounded-lg h-10 md:h-12 outline outline-1 -outline-offset-1 outline-opecgray focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-opec ps-4" placeholder="Search our website..."/>
            </div>
            <div class="p-2">
                &nbsp;<button class="bg-opec rounded-lg px-4 text-white h-10 md:h-12 align-middle" onclick="doSearch()">Search</button>
            </div>
            <div class="p-0">
                <a class="cursor-pointer p-2" onclick="hideSearch(true)">
                    &nbsp;<i class="fa-light fa-times fa-xl text-gray-500"></i>&nbsp;
                </a>
            </div>
        </div>

        <div id="searchResults" class="mt-3 lg:mt-6 text-base text-opecgray">

            
            
            

        </div>
    </div>
</div>

<script>

    const searchBar = document.getElementById("searchBar");
    const searchInput = document.getElementById('searchInput');
    const searchResults = document.getElementById('searchResults');

    //searchInput.addEventListener('keydown', (event) => {
    searchInput.addEventListener('keyup', (event) => {
        if (event.key === 'Enter') {
            doSearch('search');
        }
        else {
            doSearch('autocomplete');
        }
    });

    function toggleSearch()
    {
        if (searchBar.classList.contains('hidden')) {
            showSearch();
        }
        else {
            hideSearch();
        }
    }

    function toggleMobileSearch()
    {
        if (searchBar.classList.contains('hidden')) {
            showSearch();
            if (hamburgerOpen) {
                hamburgerOpen = !hamburgerOpen;
                hideNav(visibleSubmenus.pop());
                document.getElementById("mobileHeader").classList.remove('fixed');
                document.body.classList.remove('overflow-hidden');
                if(hamburger.classList.contains('is-active')) {
                    hamburger.classList.remove('is-active');
                }
            }
        }
        else {
            hideSearch();
        }
    }


    function showSearch()
    {
        searchBar.classList.remove("hidden");
        searchBar.classList.add("inline-block");

        setTimeout(() => {
            searchBar.classList.remove("opacity-0");
            searchBar.classList.add("opacity-100");
        }, 100);

        const sb = document.getElementById('searchInput');
        sb.focus();
    }

    function hideSearch(clearInput = false)
    {
        searchBar.classList.remove("opacity-100");
        searchBar.classList.add("opacity-0");

        setTimeout(() => {
            searchBar.classList.remove("inline-block");
            searchBar.classList.add("hidden");
            if(clearInput) {
                searchResults.innerHTML = '';
                searchInput.value = '';
            }
        }, 500);
    }

    function doSearch(searchType = 'search')
    {
        history.pushState(null, '', window.location.pathname);

        const linkPrefix = './';
        const documentPrefix = './assets/assetdb/';

        let searchTerm = document.getElementById('searchInput').value;
        console.log(searchTerm +": "+ searchTerm.length);
        if(searchTerm.length < 3) {
            let msg = '';
            msg += '<div class="flex mx-3 lg:mx-8 mb-3 px-4 lg:px-8 py-4 justify-center items-center">';
            msg += '    <div class="text-xl text-gray-400">Please enter at least 3 search characters</div>';
            msg += '</div>';
            searchResults.innerHTML = msg;
            return;
        }

        let formData = new FormData();
        //formData.append('requestType', 'search');
        formData.append('requestType', searchType);
        formData.append('query', searchTerm);

        let resultHtml = '';
        resultHtml += '<div class="flex mx-3 lg:mx-8 mb-3 px-4 lg:px-8 py-4 justify-center items-center">';
        resultHtml += '    <div class="text-opec me-4"><i class="fa-light fa-spinner-third fa-spin fa-xl"></i></div>';
        resultHtml += '    <div class="text-xl text-gray-400">searching...</div>';
        resultHtml += '</div>';

        searchResults.innerHTML = resultHtml;

        fetch("./assets/FrontendHandler.php", {
            method: 'POST',
            body: formData
        })
            .then(response => response.json())
            .then(data => {

                console.log(data);
                resultHtml = '';

                if(data.length > 0) {
                    for (i = 0; i < data.length; i++) {
                        let result = data[i];

                        if (result.pageName === '-') {
                            resultHtml += '<div class="mx-3 lg:mx-8 mb-3 px-4 lg:px-8 py-4 shadow-md hover:shadow-xl rounded-lg bg-gray-50">';
                            resultHtml += '    <h1 class="text-xl font-semibold">';
                            resultHtml += '        <a href="' + linkPrefix + result.filename + '" target="_blank">';
                            //resultHtml += '        <a href="' + linkPrefix + result.html + '">';
                            resultHtml += '            ' + result.html + '';
                            resultHtml += '            <span class="text-opec ms-2"><i class="fa-light fa-arrow-up-right"></i></span>';
                            resultHtml += '        </a>';
                            resultHtml += '    </h1>';
                            //resultHtml += '    <span class="text-sm text-gray-400">' + result.path + '</span>';
                            if(result.highlight !== null) {
                                resultHtml += '    <p class="mt-2">' + result.highlight + '</p>';
                            }
                            resultHtml += '</div>';
                        } else {
                            resultHtml += '<div class="mx-3 lg:mx-8 mb-3 px-4 lg:px-8 py-4 shadow-md hover:shadow-xl rounded-lg bg-gray-50">';
                            resultHtml += '    <h1 class="text-xl font-semibold">';
                            resultHtml += '        <a href="' + linkPrefix + result.filename + '">';
                            //resultHtml += '        <a href="' + linkPrefix + result.html + '">';
                            resultHtml += '            ' + result.pageName + '';
                            resultHtml += '            <span class="text-opec ms-2"><i class="fa-light fa-arrow-up-right"></i></span>';
                            resultHtml += '        </a>';
                            resultHtml += '    </h1>';
                            //resultHtml += '    <span class="text-sm text-gray-400">' + result.path + '</span>';
                            resultHtml += '    <p class="my-1 font-semibold">' + result.html + '</p>';
                            if(result.highlight !== null) {
                                resultHtml += '    <p class="mt-2">' + result.highlight + '</p>';
                            }
                            resultHtml += '</div>';
                        }
                    }
                }
                else {
                    resultHtml = '';
                    resultHtml += '<div class="flex mx-3 lg:mx-8 mb-3 px-4 lg:px-8 py-4 justify-center items-center">';
                    resultHtml += '    <div class="text-xl text-gray-400">No results found</div>';
                    resultHtml += '</div>';
                }

                searchResults.innerHTML = resultHtml;
            })
            .catch(error => {
                console.error('Error:', error);
                resultHtml = '';
                resultHtml += '<div class="flex mx-3 lg:mx-8 mb-3 px-4 lg:px-8 py-4 justify-center items-center">';
                resultHtml += '    <div class="text-xl text-gray-400">No results found</div>';
                resultHtml += '</div>';

                searchResults.innerHTML = resultHtml;
            });
    }


</script>
    
    
            
