p0kp534xt]&amp;x2=[responsive]&amp;x3=[news-persian]&amp;x4=[fa]&amp;x7=[index-home]&amp;x8=[simorgh-nojs]&amp;x9=[BBC%2520News%2520%D9%81%D8%A7%D8%B1%D8%B3%DB%8C]"/></noscript><h1 id="content" tabindex="-1" class="css-2ozlq5"><span role="text"><span lang="en-GB">BBC News</span>, <!-- -->فارسی<!-- --> - <!-- -->صفحه اول</span></h1><div class="css-edorhv"><div class="css-1ajedpd"><div class="css-h3mcdy"><section role="region" aria-labelledby="billboard-1" data-testid="billboard-1"><div class="css-pdr2dp"><div class="css-fu2t6"></div><div class="css-1pu1y7a"><div class="css-4f24n9"><div class="css-1pzjeop" style="padding-bottom:0;overflow:hidden"><picture><source srcSet="https://ichef.bbci.co.uk/ace/ws/240/cpsprodpb/514f/live/732674d0-19d3-11f1-801d-ed3cff6bf876.jpg.webp 240w, https://ichef.bbci.co.uk/ace/ws/320/cpsprodpb/514f/live/732674d0-19d3-11f1-801d-ed3cff6bf876.jpg.webp 320w, https://ichef.bbci.co.uk/ace/ws/480/cpsprodpb/514f/live/732674d0-19d3-11f1-801d-ed3cff6bf876.jpg.webp 480w, https://ichef.bbci.co.uk/ace/ws/624/cpsprodpb/514f/live/732674d0-19d3-11f1-801d-ed3cff6bf876.jpg.webp 624w, https://ichef.bbci.co.uk/ace/ws/660/cpsprodpb/514f/live/732674d0-19d3-11f1-801d-ed3cff6bf876.jpg.webp 660w" type="image/webp" sizes="(min-width: 1008px) 660px, 100vw"/><source srcSet="https://ichef.bbci.co.uk/ace/ws/240/cpsprodpb/514f/live/732674d0-19d3-11f1-801d-ed3cff6bf876.jpg 240w, https://ichef.bbci.co.uk/ace/ws/320/cpsprodpb/514f/live/732674d0-19d3-11f1-801d-ed3cff6bf876.jpg 320w, https://ichef.bbci.co.uk/ace/ws/480/cpsprodpb/514f/live/732674d0-19d3-11f1-801d-ed3cff6bf876.jpg 480w, https://ichef.bbci.co.uk/ace/ws/624/cpsprodpb/514f/live/732674d0-19d3-11f1-801d-ed3cff6bf876.jpg 624w, https://ichef.bbci.co.uk/ace/ws/660/cpsprodpb/514f/live/732674d0-19d3-11f1-801d-ed3cff6bf876.jpg 660w" type="image/jpeg" sizes="(min-width: 1008px) 660px, 100vw"/><img src="https://ichef.bbci.co.uk/ace/ws/240/cpsprodpb/514f/live/732674d0-19d3-11f1-801d-ed3cff6bf876.jpg.webp" alt="جنگ آمریکا و اسرائیل با ایران" loading="eager" fetchPriority="high" style="aspect-ratio:auto" class="css-ey0vwc"/></picture></div></div><div class="css-d0r6if"><h2 class="css-pkkbfx" id="billboard-1"><a href="https://www.bbc.com/persian/live/cp814rkpz1rt" data-static-reverb-click="https://a1.api.bbc.co.uk/hit.xiti?idclient={idclient}&amp;s=598342&amp;r={screenResolutionColourDepth}&amp;re={browserViewportResolution}&amp;hl={timestamp}&amp;ts={epochTimestamp}&amp;lng={language}&amp;app_type=lite&amp;app_name=news-persian&amp;language=fa&amp;content_type=home&amp;events=%5B%7B%22name%22%3A%22viewability.select%22%2C%22data%22%3A%7B%22item%22%3A%7B%22name%22%3A%22billboard%22%2C%22link%22%3A%22{forwardingLink}%22%7D%2C%22event%22%3A%7B%22category%22%3A%22viewability%22%2C%22action%22%3A%22select%22%7D%2C%22group%22%3A%7B%22name%22%3A%22%D8%AC%D9%86%DA%AF%20%D8%A2%D9%85%D8%B1%DB%8C%DA%A9%D8%A7%20%D9%88%20%D8%A7%D8%B3%D8%B1%D8%A7%D8%A6%DB%8C%D9%84%20%D8%A8%D8%A7%20%D8%A7%DB%8C%D8%B1%D8%A7%D9%86%22%2C%22type%22%3A%22billboard%22%2C%22item_count%22%3A1%2C%22resource_id%22%3A%22urn%3Abbc%3Atipo%3Alist%3A70cdc9bd-4385-4888-b608-05e2a011bef2%22%2C%22position%22%3A1%7D%2C%22user%22%3A%7B%22id%22%3Anull%7D%2C%22app%22%3A%7B%22type%22%3A%22lite%22%2C%22name%22%3A%22news-persian%22%7D%7D%7D%5D&amp;context=%5B%7B%22data%22%3A%7B%22page%22%3A%7B%22%24%22%3A%22persian.page%22%7D%2C%22site%22%3A%7B%22level2_id%22%3A69%7D%7D%7D%5D" class="css-dsoym6"><div>انفجارهای مهیبی، فرودگاه مهرآباد تهران را لرزاند؛ اسرائیل: «زیرساخت‌های رژیم» را هدف قرار دادیم</div></a></h2><p class="css-hb3ffz">شب گذشته اسرائیل اعلام کرد که حملات گسترده‌ای را در تهران به اجرا گذاشته است. همزمان تصاویری در شبکه‌های اجتماعی منتشر شد که نشان‌می‌دهند قسمتی از فرودگاه مهرآباد تهران هدف قرار گرفته است. دونالد ترامپ، گفت که ارتش آمریکا در نابودی نیروهای نظامی ایران «به‌طور فوق‌العاده‌ای» عمل کرده است و ارتش جمهوری اسلامی از بین رفته است. فرماندهی مرکزی ایالات متحده هم اعلام کرد که به بیش از سه هزار هدف در ایران حمله کرده است. آقای ترامپ به پایگاه خبری اکسیوس گفت که درخواستش از ایران برای تسلیم بی‌قید و شرط می‌تواند به معنای نابودی کامل توانایی‌های نظامی حکومت ایران باشد. او همچنین خبر داد که با بزرگ‌ترین شرکت‌های تولیدکننده تسلیحات در آمریکا برای چهار برابر کردن تولید سلاح‌های پیشرفته توافق کرده‌ است.</p></div></div></div></section></div><section aria-labelledby="high-collection-1" role="region"><div><h2 id="high-collection-1" class="css-fsh66c">مهمترین خبرها</h2><div data-testid="hierarchical-grid"><ul role="list" data-testid="topic-promos" class="css-1rrncb9"><li class="css-bm7rse"><div class="css-79elbk ez03et70"><div class="promo-image"><div class="css-15d53do e4m0ur80"><div class="css-1avk5os" style="padding-bottom:56.25%;overflow:hidden"><picture><source srcSet="https://ichef.bbci.co.uk/ace/ws/85/cpsprodpb/2d15/live/accd0c40-189c-11f1-a247-59d304ef583d.jpg.webp 85w, https://ichef.bbci.co.uk/ace/ws/120/cpsprodpb/2d15/live/accd0c40-189c-11f1-a247-59d304ef583d.jpg.webp 120w, https://ichef.bbci.co.uk/ace/ws/170/cpsprodpb/2d15/live/accd0c40-189c-11f1-a247-59d304ef583d.jpg.webp 170w, https://ichef.bbci.co.uk/ace/ws/232/cpsprodpb/2d15/live/accd0c40-189c-11f1-a247-59d304ef583d.jpg.webp 232w, https://ichef.bbci.co.uk/ace/ws/325/cpsprodpb/2d15/live/accd0c40-189c-11f1-a247-59d304ef583d.jpg.webp 325w, https://ichef.bbci.co.uk/ace/ws/450/cpsprodpb/2d15/live/accd0c40-189c-11f1-a247-59d304ef583d.jpg.webp 450w, https://ichef.bbci.co.uk/ace/ws/660/cpsprodpb/2d15/live/accd0c40-189c-11f1-a247-59d304ef583d.jpg.webp 660w, https://ichef.bbci.co.uk/ace/ws/800/cpsprodpb/2d15/live/accd0c40-189c-11f1-a247-59d304ef583d.jpg.webp 800w" type="image/webp" sizes="(min-width: 63rem) 800px, (min-width: 37.5rem) 66vw, 100vw"/><source srcSet="https://ichef.bbci.co.uk/ace/ws/85/cpsprodpb/2d15/live/accd0c40-189c-11f1-a247-59d304ef583d.jpg 85w, https://ichef.bbci.co.uk/ace/ws/120/cpsprodpb/2d15/live/accd0c40-189c-11f1-a247-59d304ef583d.jpg 120w, https://ichef.bbci.co.uk/ace/ws/170/cpsprodpb/2d15/live/accd0c40-189c-11f1-a247-59d304ef583d.jpg 170w, https://ichef.bbci.co.uk/ace/ws/232/cpsprodpb/2d15/live/accd0c40-189c-11f1-a247-59d304ef583d.jpg 232w, https://ichef.bbci.co.uk/ace/ws/325/cpsprodpb/2d15/live/accd0c40-189c-11f1-a247-59d304ef583d.jpg 325w, https://ichef.bbci.co.uk/ace/ws/450/cpsprodpb/2d15/live/accd0c40-189c-11f1-a247-59d304ef583d.jpg 450w, https://ichef.bbci.co.uk/ace/ws/660/cpsprodpb/2d15/live/accd0c40-189c-11f1-a247-59d304ef583d.jpg 660w, https://ichef.bbci.co.uk/ace/ws/800/cpsprodpb/2d15/live/accd0c40-189c-11f1-a247-59d304ef583d.jpg 800w" type="image/jpeg" sizes="(min-width: 63rem) 800px, (min-width: 37.5rem) 66vw, 100vw"/><img src="https://ichef.bbci.co.uk/ace/ws/240/cpsprodpb/2d15/live/accd0c40-189c-11f1-a247-59d304ef583d.jpg.webp" alt="یک عضو مسلح سپاه پاسداران انقلاب اسلامی در برابر پرچم ایران یک تفنگ ای‌کی۴۷ در دست دارد" loading="lazy" style="aspect-ratio:16 / 9" class="css-1seqhu9"/></picture></div></div></div><div class="promo-text"><h3 class="css-mdj7p5 ez3pb4d0"><a href="https://www.bbc.com/persian/articles/cr5l1q0rj2mo" data-static-reverb-click="https://a1.api.bbc.co.uk/hit.xiti?idclient={idclient}&amp;s=598342&amp;r={screenResolutionColourDepth}&amp;re={browserViewportResolution}&amp;hl={timestamp}&amp;ts={epochTimestamp}&amp;lng={language}&amp;app_type=lite&amp;app_name=news-persian&amp;language=fa&amp;content_type=home&amp;events=%5B%7B%22name%22%3A%22viewability.select%22%2C%22data%22%3A%7B%22item%22%3A%7B%22name%22%3A%22hierarchical-curation-grid%22%2C%22type%22%3A%22hierarchical-curation-grid-promo%22%2C%22text%22%3A%22%D8%A7%DB%8C%D8%B1%D8%A7%D9%86%20%D8%AA%D9%88%D8%A7%D9%86%20%D8%B4%DA%A9%D8%B3%D8%AA%20%D9%86%D8%B8%D8%A7%D9%85%DB%8C%20%D8%A2%D9%85%D8%B1%DB%8C%DA%A9%D8%A7%20%D8%B1%D8%A7%20%D9%86%D8%AF%D8%A7%D8%B1%D8%AF%D8%8C%20%D8%A7%D9%85%D8%A7%20%D8%B1%D8%A7%D9%87%D8%A8%D8%B1%D8%AF%20%D8%B1%D9%87%D8%A8%D8%B1%D8%A7%D9%86%D8%B4%20%D8%A8%D8%B1%D8%A7%DB%8C%20%D8%A8%D9%82%D8%A7%20%DA%86%DB%8C%D8%B3%D8%AA%D8%9F%22%2C%22position%22%3A1%2C%22media_type%22%3A%22article%22%2C%22resource_id%22%3A%22cr5l1q0rj2mo%22%2C%22link%22%3A%22{forwardingLink}%22%7D%2C%22event%22%3A%7B%22category%22%3A%22viewability%22%2C%22action%22%3A%22select%22%7D%2C%22group%22%3A%7B%22name%22%3A%22%D9%85%D9%87%D9%85%D8%AA%D8%B1%DB%8C%D9%86%20%D8%AE%D8%A8%D8%B1%D9%87%D8%A7%22%2C%22type%22%3A%22hierarchical-curation-grid%22%2C%22item_count%22%3A5%2C%22resource_id%22%3A%22urn%3Abbc%3Atipo%3Alist%3A362895c7-2b82-43d8-8f76-9c8106734bc9%22%2C%22position%22%3A2%7D%2C%22user%22%3A%7B%22id%22%3Anull%7D%2C%22app%22%3A%7B%22type%22%3A%22lite%22%2C%22name%22%3A%22news-persian%22%7D%7D%7D%5D&amp;context=%5B%7B%22data%22%3A%7B%22page%22%3A%7B%22%24%22%3A%22persian.page%22%7D%2C%22site%22%3A%7B%22level2_id%22%3A69%7D%7D%7D%5D" class="css-1i4ie53 eq53xv90">ایران توان شکست نظامی آمریکا را ندارد، اما راهبرد رهبرانش برای بقا چیست؟</a></h3><p class="promo-paragraph css-5geeij ehp2s2u0">آمریکا و اسرائیل می‌گویند که حملات هوایی مشترک و مداوم آن‌ها توانایی‌های نظامی ایران را به‌شدت تضعیف کرده است. دونالد ترامپ گفت که «پدافند هوایی، نیروی هوایی، نیروی دریایی و رهبری آن‌ها از بین رفته است.» ایران در جواب با حملاتی علیه اسرائیل و کشورهای میزبان پایگاه‌های نظامی آمریکا در خاورمیانه، اعلام کرد که در حال دفاع از خود است. با توجه به اینکه اسرائیل و ایالات متحده از نظر نظامی برتر تلقی می‌شوند، ایران در این جنگ چه گزینه‌هایی دارد و چه راهبردی را دنبال می‌کند؟</p><time dateTime="2026-03-07" class="promo-timestamp css-14j0rwe e9szwfh0">۳ ساعت پیش</time></div></div></li><li class="css-qyyagp"><div class="css-79elbk ez03et70"><div class="promo-image"><div class="css-15d53do e4m0ur80"><div class="css-1avk5os" style="padding-bottom:56.25%;overflow:hidden"><picture><source srcSet="https://ichef.bbci.co.uk/ace/ws/85/cpsprodpb/76ad/live/ebc0f2a0-1968-11f1-8943-0f02ddbbd48f.jpg.webp 85w, https://ichef.bbci.co.uk/ace/ws/120/cpsprodpb/76ad/live/ebc0f2a0-1968-11f1-8943-0f02ddbbd48f.jpg.webp 120w, https://ichef.bbci.co.uk/ace/ws/170/cpsprodpb/76ad/live/ebc0f2a0-1968-11f1-8943-0f02ddbbd48f.jpg.webp 170w, https://ichef.bbci.co.uk/ace/ws/232/cpsprodpb/76ad/live/ebc0f2a0-1968-11f1-8943-0f02ddbbd48f.jpg.webp 232w, https://ichef.bbci.co.uk/ace/ws/325/cpsprodpb/76ad/live/ebc0f2a0-1968-11f1-8943-0f02ddbbd48f.jpg.webp 325w, https://ichef.bbci.co.uk/ace/ws/450/cpsprodpb/76ad/live/ebc0f2a0-1968-11f1-8943-0f02ddbbd48f.jpg.webp 450w, https://ichef.bbci.co.uk/ace/ws/660/cpsprodpb/76ad/live/ebc0f2a0-1968-11f1-8943-0f02ddbbd48f.jpg.webp 660w, https://ichef.bbci.co.uk/ace/ws/800/cpsprodpb/76ad/live/ebc0f2a0-1968-11f1-8943-0f02ddbbd48f.jpg.webp 800w" type="image/webp" sizes="(min-width: 63rem) 232px, (min-width: 37.5rem) 50vw, 33vw"/><source srcSet="https://ichef.bbci.co.uk/ace/ws/85/cpsprodpb/76ad/live/ebc0f2a0-1968-11f1-8943-0f02ddbbd48f.jpg 85w, https://ichef.bbci.co.uk/ace/ws/120/cpsprodpb/76ad/live/ebc0f2a0-1968-11f1-8943-0f02ddbbd48f.jpg 120w, https://ichef.bbci.co.uk/ace/ws/170/cpsprodpb/76ad/live/ebc0f2a0-1968-11f1-8943-0f02ddbbd48f.jpg 170w, https://ichef.bbci.co.uk/ace/ws/232/cpsprodpb/76ad/live/ebc0f2a0-1968-11f1-8943-0f02ddbbd48f.jpg 232w, https://ichef.bbci.co.uk/ace/ws/325/cpsprodpb/76ad/live/ebc0f2a0-1968-11f1-8943-0f02ddbbd48f.jpg 325w, https://ichef.bbci.co.uk/ace/ws/450/cpsprodpb/76ad/live/ebc0f2a0-1968-11f1-8943-0f02ddbbd48f.jpg 450w, https://ichef.bbci.co.uk/ace/ws/660/cpsprodpb/76ad/live/ebc0f2a0-1968-11f1-8943-0f02ddbbd48f.jpg 660w, https://ichef.bbci.co.uk/ace/ws/800/cpsprodpb/76ad/live/ebc0f2a0-1968-11f1-8943-0f02ddbbd48f.jpg 800w" type="image/jpeg" sizes="(min-width: 63rem) 232px, (min-width: 37.5rem) 50vw, 33vw"/><img src="https://ichef.bbci.co.uk/ace/ws/240/cpsprodpb/76ad/live/ebc0f2a0-1968-11f1-8943-0f02ddbbd48f.jpg.webp" alt="ردیف موشک‌ها در یک شهر موشکی" loading="lazy" style="aspect-ratio:16 / 9" class="css-1seqhu9"/></picture></div></div></div><div class="promo-text"><h3 class="css-1y4eg8c ez3pb4d0"><a href="https://www.bbc.com/persian/articles/c178vxlen22o" data-static-reverb-click="https://a1.api.bbc.co.uk/hit.xiti?idclient={idclient}&amp;s=598342&amp;r={screenResolutionColourDepth}&amp;re={browserViewportResolution}&amp;hl={timestamp}&amp;ts={epochTimestamp}&amp;lng={language}&amp;app_type=lite&amp;app_name=news-persian&amp;language=fa&amp;content_type=home&amp;events=%5B%7B%22name%22%3A%22viewability.select%22%2C%22data%22%3A%7B%22item%22%3A%7B%22name%22%3A%22hierarchical-curation-grid%22%2C%22type%22%3A%22hierarchical-curation-grid-promo%22%2C%22text%22%3A%22%D8%A7%D8%B3%D8%AA%D8%B1%D8%A7%D8%AA%DA%98%DB%8C%20%D9%BE%D8%B1%D8%AE%D8%B7%D8%B1%20%D8%A7%DB%8C%D8%B1%D8%A7%D9%86%20%D8%AF%D8%B1%20%D8%AC%D9%86%DA%AF%20%D8%A8%D8%A7%20%D8%A2%D9%85%D8%B1%DB%8C%DA%A9%D8%A7%20%D9%88%20%D8%A7%D8%B3%D8%B1%D8%A7%D8%A6%DB%8C%D9%84%D8%9B%20%D8%AA%DA%A9%DB%8C%D9%87%20%D8%A8%D8%B1%20%D8%AA%D8%A7%D8%A8%E2%80%8C%D8%A2%D9%88%D8%B1%DB%8C%20%D9%88%20%D8%A8%D8%A7%D8%B2%D8%AF%D8%A7%D8%B1%D9%86%D8%AF%DA%AF%DB%8C%22%2C%22position%22%3A2%2C%22media_type%22%3A%22article%22%2C%22resource_id%22%3A%22c178vxlen22o%22%2C%22link%22%3A%22{forwardingLink}%22%7D%2C%22event%22%3A%7B%22category%22%3A%22viewability%22%2C%22action%22%3A%22select%22%7D%2C%22group%22%3A%7B%22name%22%3A%22%D9%85%D9%87%D9%85%D8%AA%D8%B1%DB%8C%D9%86%20%D8%AE%D8%A8%D8%B1%D9%87%D8%A7%22%2C%22type%22%3A%22hierarchical-curation-grid%22%2C%22item_count%22%3A5%2C%22resource_id%22%3A%22urn%3Abbc%3Atipo%3Alist%3A362895c7-2b82-43d8-8f76-9c8106734bc9%22%2C%22position%22%3A2%7D%2C%22user%22%3A%7B%22id%22%3Anull%7D%2C%22app%22%3A%7B%22type%22%3A%22lite%22%2C%22name%22%3A%22news-persian%22%7D%7D%7D%5D&amp;context=%5B%7B%22data%22%3A%7B%22page%22%3A%7B%22%24%22%3A%22persian.page%22%7D%2C%22site%22%3A%7B%22level2_id%22%3A69%7D%7D%7D%5D" class="css-1i4ie53 eq53xv90">استراتژی پرخطر ایران در جنگ با آمریکا و اسرائیل؛ تکیه بر تاب‌آوری و بازدارندگی</a></h3><p class="promo-paragraph css-5geeij ehp2s2u0">آرایش و رویکرد نظامی ایران در جنگ رو به گسترش با اسرائیل و آمریکا نشان می‌دهد که این کشور در پی پیروزی به معنای متعارف آن نیست. ایران برای بقا می‌جنگد؛ بقایی که آن را بر اساس شرایط و قواعد مورد نظر خود تعریف می‌کند.
رهبران و فرماندهان جمهوری اسلامی سال‌هاست برای چنین لحظه‌ای آماده شده‌اند.
آن‌ها می‌دانستند که جاه‌طلبی‌های منطقه‌ای‌شان ممکن است در نهایت به رویارویی مستقیم با اسرائیل یا ایالات متحده منجر شود و جنگ با یکی از آن‌ها تقریبا به طور قطع پای دیگری را نیز به میان خواهد کشید. این الگو در جنگ ۱۲ روزه تابستان گذشته آشکار بود که اسرائیل نخست حمله کرد و ایالات متحده چند روز بعد به آن پیوست.</p><time dateTime="2026-03-06" class="promo-timestamp css-14j0rwe e9szwfh0">۹ ساعت پیش</time></div></div></li><li class="css-jw2yjd"><div class="css-79elbk ez03et70"><div class="promo-image"><div class="css-15d53do e4m0ur80"><div class="css-1avk5os" style="padding-bottom:56.25%;overflow:hidden"><picture><source srcSet="https://ichef.bbci.co.uk/ace/ws/85/cpsprodpb/8cf2/live/ca7c6310-197a-11f1-9120-a910fc22c6ac.jpg.webp 85w, https://ichef.bbci.co.uk/ace/ws/120/cpsprodpb/8cf2/live/ca7c6310-197a-11f1-9120-a910fc22c6ac.jpg.webp 120w, https://ichef.bbci.co.uk/ace/ws/170/cpsprodpb/8cf2/live/ca7c6310-197a-11f1-9120-a910fc22c6ac.jpg.webp 170w, https://ichef.bbci.co.uk/ace/ws/232/cpsprodpb/8cf2/live/ca7c6310-197a-11f1-9120-a910fc22c6ac.jpg.webp 232w, https://ichef.bbci.co.uk/ace/ws/325/cpsprodpb/8cf2/live/ca7c6310-197a-11f1-9120-a910fc22c6ac.jpg.webp 325w, https://ichef.bbci.co.uk/ace/ws/450/cpsprodpb/8cf2/live/ca7c6310-197a-11f1-9120-a910fc22c6ac.jpg.webp 450w, https://ichef.bbci.co.uk/ace/ws/660/cpsprodpb/8cf2/live/ca7c6310-197a-11f1-9120-a910fc22c6ac.jpg.webp 660w, https://ichef.bbci.co.uk/ace/ws/800/cpsprodpb/8cf2/live/ca7c6310-197a-11f1-9120-a910fc22c6ac.jpg.webp 800w" type="image/webp" sizes="(min-width: 63rem) 232px, (min-width: 37.5rem) 50vw, 33vw"/><source srcSet="https://ichef.bbci.co.uk/ace/ws/85/cpsprodpb/8cf2/live/ca7c6310-197a-11f1-9120-a910fc22c6ac.jpg 85w, https://ichef.bbci.co.uk/ace/ws/120/cpsprodpb/8cf2/live/ca7c6310-197a-11f1-9120-a910fc22c6ac.jpg 120w, https://ichef.bbci.co.uk/ace/ws/170/cpsprodpb/8cf2/live/ca7c6310-197a-11f1-9120-a910fc22c6ac.jpg 170w, https://ichef.bbci.co.uk/ace/ws/232/cpsprodpb/8cf2/live/ca7c6310-197a-11f1-9120-a910fc22c6ac.jpg 232