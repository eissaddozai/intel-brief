    <div>
<script type="text/javascript">
            document.addEventListener( 'CoveoSearchEndpointInitialized', function () {

				function CleanSummaries() {
					var summaryContainers = document.getElementsByClassName( 'wtw-listing-result-summary' );
					if(summaryContainers != null){
					for ( var i = 0; i < summaryContainers.length; i++ ) {
						var rawSummary = summaryContainers[i].innerHTML;
						var refinedSummary = rawSummary.replace( /<[^>]+>/g, '' );
						summaryContainers[i].innerHTML = refinedSummary;
					}
					}
				}

				function NewPagerIcons() {
					var next = document.getElementsByClassName( 'coveo-pager-next-icon' )[0];
					var prev = document.getElementsByClassName( 'coveo-pager-previous-icon' )[0];

					if ( next != null  ) {
						var newNext = document.createElement( 'img' );
						newNext.classList.add( 'img-fluid', 'coveo-pager-next-icon-svg' );
						newNext.alt = '';
						newNext.setAttribute( 'aria-hidden', 'true' );
						newNext.src = "/-/Media/Feature/Resources/Images/icons/forward-arrow.svg";
						next.innerHTML = '';
						next.appendChild( newNext );
						next.parentElement.setAttribute( "title", ">" );
					}

					if ( prev != null ) {
						var newPrev = document.createElement( 'img' );
						newPrev.classList.add( 'img-fluid', 'coveo-pager-previous-icon-svg' );
						newPrev.alt = '';
						newPrev.setAttribute( 'aria-hidden', 'true' );
						newPrev.src = "/-/Media/Feature/Resources/Images/icons/back-arrow.svg";
						prev.innerHTML = '';
						prev.appendChild( newPrev );
						prev.parentElement.setAttribute( "title", "<" );
					}
				}

				function UpdateMoreFacetFooters() {
					var facetFooters = document.querySelectorAll( 'div.coveo-facet-footer div.coveo-facet-more' );
					if ( facetFooters != null ) {
						for ( var i = 0; i < facetFooters.length; i++ ) {
							var facetFooter = facetFooters[i];
							facetFooter.setAttribute( "title", "view more filters" );
							facetFooter.setAttribute( "aria-label", "button, click to view more filters" );
						}
					}
				}

				function UpdateLessFacetFooters() {
					var facetFooters = document.querySelectorAll( 'div.coveo-facet-footer div.coveo-facet-less' );
					if ( facetFooters != null ) {
						for ( var i = 0; i < facetFooters.length; i++ ) {
							var facetFooter = facetFooters[i];
							facetFooter.setAttribute( "title", "view less filters" );
							facetFooter.setAttribute( "aria-label", "button, click to view less filters" );
						}
					}
				}

				function UpdateExcludeButtons() {
					var excludes = document.querySelectorAll( 'ul.coveo-facet-values li.coveo-facet-value div.coveo-facet-value-exclude' );
					if ( excludes != null ) {
						for ( var i = 0; i < excludes.length; i++ ) {
							var exclude = excludes[i];
                            exclude.innerHTML = "<span aria-hidden=\"true\" class=\"material-symbols-outlined coveo-facet-value-exclude-svg\">close</span>";
						}
					}
				}

				function FormatAuthorLine() {
					var authorLines = document.getElementsByClassName( 'wtw-coveo-author-field' );
					if(authorLines != null){
					for ( var i = 0; i < authorLines.length; i++ ) {
						var cleanLine = "By ";
                        var authors = authorLines[i].innerHTML.split(', ');
						if ( authors.length > 0 ) {
                            for (var j = 0; j < authors.length; j++) {
                                var shouldAddSeparator = (j < authors.length - 1);
								var separator = ( j == authors.length - 2 ) ? ' '+'and' + ' ' : ', ';
								cleanLine += shouldAddSeparator ? ( authors[j] + separator ) : authors[j];
							}
						}
                        authorLines[i].innerHTML = cleanLine;
					}
					}
				}

				function PipeDelimitInlineFields() {
					var inlineTables = document.getElementsByClassName( 'wtw-inline-field-container' );
					if(inlineTables != null){
					for ( var i = 0; i < inlineTables.length; i++ ) {
						var inlineTds = inlineTables[i].querySelectorAll( 'td.wtw-inline-field' );
						for ( var j = 0; j < inlineTds.length - 1; j++ ) {
							if ( inlineTds[j].innerHTML != null && inlineTds[j + 1].innerHTML != null ) {
								inlineTds[j].innerHTML += "<span class=\"wtw-pipe\">|</span>"
							}
						}
					}
					}
				}

                function UpdateClearBreadcrumbs() {
                    var clearBreadcrumbFilter = Coveo.$$( document ).find( 'div .coveo-breadcrumb-clear-all' );
                    if ( clearBreadcrumbFilter != null ) {
                        clearBreadcrumbFilter.setAttribute( 'aria-label', 'button, click to clear all selected filters' );
                        clearBreadcrumbFilter.setAttribute( 'aria-pressed', 'false' );
                        clearBreadcrumbFilter.setAttribute('role', 'button');

                    }
                }

                function UpdateClearFacets() {
                    var clearFilter = Coveo.$$( document ).find( 'div .coveo-facet-header-eraser.coveo-facet-header-eraser-visible' );
                    if ( clearFilter != null ) {
                        clearFilter.setAttribute( 'aria-label', 'button, click to clear all selected filters' );
                        clearFilter.setAttribute( 'aria-pressed', 'false' );
                        clearFilter.setAttribute( 'role', 'button' );
                        clearFilter.setAttribute( 'tabindex', '0' );
                    }
                }

                function updateResultLinkAttributes() {
                    var resultTitle = document.querySelectorAll('.CoveoResultLink.wtw-listing-result-title');
                    if (resultTitle != null) {
                        resultTitle.forEach(function (ele) {
                            ele.removeAttribute('tabindex');
                        });
                    }
				}

                function getQueryParameters(url) {
                    const queryStringContentTypeFacetName = "ARTICLEZ45XCONTENTZ45XTYPE";
                    const queryStringDateFacetName = "DISPLAYZ45XDATE";
                    const facetContentTypeTitle = "CONTENT TYPE";
                    const facetDateTitle = "DATE";

                    var search_filter = "";

                    var queryString = url.split("#")[1];

                    var params = [];

                    if (queryString) {
                        var paramArray = queryString.split('&'); // Split the query string into an array of key-value pairs

                        for (var i = 0, j = 0; i < paramArray.length; i++) {
                            var param = paramArray[i].split('=');
                            var paramName = decodeURIComponent(param[0]);
                            var paramValue = decodeURIComponent(param[1]).replace("[","").replace("]","");
                            if (!paramName.includes("sort") && !paramName.includes("q")) {
                                params[j] = paramName.replace("f:@", "").toUpperCase().replace(queryStringContentTypeFacetName, facetContentTypeTitle).replace(queryStringDateFacetName, facetDateTitle) + " : " + paramValue;
                                j = j + 1;
                            }
                        }
                    }

                    for (var i = 0; i < params.length ; i++) {
                        //if params[i] contains facetDateTitle, use TranslateDateFacet() and recreate the parameter as Key +  " : "  + translated value
                        if (params[i].includes(facetDateTitle)) {
                            var keyValue = params[i].split(' : ');
                            var dateFacetKey = keyValue[0];
                            var dateFacetValue = keyValue[1];

                            params[i] = dateFacetKey + " : " + TranslateDateFacet(dateFacetValue);
                        }

                        search_filter = search_filter.concat(params[i], " | ");
                    }

                    search_filter = search_filter.replaceAll(",", " // ").slice(0, -2);

                    if (search_filter)
                        return search_filter;
                    else
                        return "None";

                }

                function TranslateDateFacet(dateFacetValue) {
                    //Split on ","
                    var translatedDateValue = "";
                    var dateValues = dateFacetValue.split(',');
                    for (var i = 0; i < dateValues.length; i++) {
                        translatedDateValue = translatedDateValue.concat(GetTranslatedDate(dateValues[i]), ",");
                    }
                    translatedDateValue = translatedDateValue.slice(0, -1).replaceAll(","," // ");

                    if (translatedDateValue)
                        return translatedDateValue;
                    else
                        return "";
                }

                function GetTranslatedDate(dateFacetValue) {
                    var translatedDateFacet = "";
                    if (dateFacetValue.includes("1900/01/01")) {
                        translatedDateFacet = "Over a year ago";
                    }
                    else if (dateFacetValue.includes("2100/10/10")) {
                        translatedDateFacet = "Last 30 days";
                    }
                    else {
                        translatedDateFacet = "31 days to a year ago";
                    }

                    return translatedDateFacet;
                }

                var root = document.getElementById( "coveo7fbd1665" );

                Coveo.$$(root).on("analyticsEventReady", (e,args) => {
                    console.log("Inside analyticsEventReady Handler");

                    if (args.coveoAnalyticsEventData.numberOfResults > 0) {

                        if (args.coveoAnalyticsEventData.actionCause == "searchboxSubmit" ||
                            args.coveoAnalyticsEventData.actionCause == "searchFromLink" ||
                            args.coveoAnalyticsEventData.actionCause == "omniboxField" ||
                            args.coveoAnalyticsEventData.actionCause == "breadcrumbFacet" ||
                            args.coveoAnalyticsEventData.actionCause == "breadcrumbResetAll"
                        ) {
                            window.dataLayer.push({
                                'event': 'search',
                                'search_term': args.coveoAnalyticsEventData.queryText,
                                'search_type': args.coveoAnalyticsEventData.actionCause,
                                'search_filter': getQueryParameters(window.location.href)
                            });
                        }

                        window.dataLayer.push({
                            'event': 'view_search_results',
                            'search_term': args.coveoAnalyticsEventData.queryText,
                            'search_type': args.coveoAnalyticsEventData.actionCause,
                            'search_filter': getQueryParameters(window.location.href),
                            'num_search_results': args.coveoAnalyticsEventData.numberOfResults
                        });
                    }
                    if (args.event == "CoveoSearchEvent") {
                        if (args.coveoAnalyticsEventData.actionCause == "facetSelect"
                            || args.coveoAnalyticsEventData.actionCause == "facetDeselect"
                            || args.coveoAnalyticsEventData.actionCause == "facetClearAll"
                        ) {
                            var filter_subcategory = (args.coveoAnalyticsEventData.customData.facetTitle.toLowerCase().includes("date")) ? TranslateDateFacet(args.coveoAnalyticsEventData.customData.facetValue) : args.coveoAnalyticsEventData.customData.facetValue;

                            window.dataLayer.push({
                                'event': 'search_filter_interaction',
                                'search_type': args.coveoAnalyticsEventData.actionCause,
                                'filter_category': args.coveoAnalyticsEventData.customData.facetTitle,
                                'filter_subcategory': filter_subcategory,
                                'num_search_results': args.coveoAnalyticsEventData.numberOfResults
                            });
                        }
                    }
                    if (args.coveoAnalyticsEventData.actionCause == "pagerNumber") {
                        window.dataLayer.push({
                            'event': 'page_view'
                        });
                    }
                });

				Coveo.$$(root).on("changeAnalyticsCustomData", (e,args) => {
                    console.log("Inside changeAnalyticsCustomData Handler");

                    if (args.type == 'ClickEvent') {
                        if (args.actionCause == "documentOpen" ||
                            args.actionCause == "recommendationOpen"
                        ) {
                            window.dataLayer.push({
                                'event': 'search_result_selected',
                                'search_term': args.resultData.state.q,
                                'search_type': args.actionCause,
                                'search_result_selected': args.resultData.title,
                                'search_filter': getQueryParameters(window.location.href)
                            });
                        }
                    }
               });

				Coveo.$$( root ).on( 'newResultsDisplayed', function () {
                    CleanSummaries();
					NewPagerIcons();
					UpdateMoreFacetFooters();
					UpdateLessFacetFooters();
					UpdateExcludeButtons();
					FormatAuthorLine();
                    PipeDelimitInlineFields();
                    updateResultLinkAttributes();
                } );

                Coveo.$$( root ).on( 'populateBreadcrumb', function () {
                    UpdateClearBreadcrumbs();
                    UpdateClearFacets();
                });

                			
                setTimeout( function () {
                    var searchInterface = document.getElementById( "coveo7fbd1665" );
					 if ( typeof ( CoveoForSitecore ) !== "undefined" ) {
						 CoveoForSitecore.initSearchInterface( searchInterface );
					 }
                }, 0 );
            } );
</script>    </div>      
</div>

            </div>
        </section>

