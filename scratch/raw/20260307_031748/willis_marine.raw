<script>
    // TODO: use TemplateIds CONSTANT and find more elegant solution
    document.addEventListener('CoveoSearchEndpointInitialized', function() {
        var expressionBuilder = new Coveo.ExpressionBuilder();
        var templateName = CoveoForSitecore.Context.fields.toCoveo('@TemplateID');
        var path = CoveoForSitecore.Context.fields.toCoveo('@_fullpath');
        var articlePage = '{4E9B7D45-60FE-4972-8C1F-9D3E802B5379}';
        var contentPathValues = [articlePage];
        var displayInListing = CoveoForSitecore.Context.fields.toCoveo('@Is Displayed On Listing Page');
        expressionBuilder.addFieldExpression(templateName, "==", contentPathValues);
        expressionBuilder.addFieldExpression(path, "*=", ["/sitecore/content/WTW/insights*"]);
        expressionBuilder.addFieldExpression(displayInListing, "==", ["1"]);
        document.getElementById('JSFilterExpression').dataset.scAdvancedFilter = expressionBuilder.build();
    });
</script>
