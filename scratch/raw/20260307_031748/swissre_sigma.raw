                    warning: '<svg width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><g stroke="none" stroke-width="1" fill="none" fill-rule="evenodd"><g transform="translate(1.000000, 1.000000)" fill="#3c4150" fill-rule="nonzero"><path d="M11,-0.75 C4.51065419,-0.75 -0.75,4.51065419 -0.75,11 C-0.75,17.4893458 4.51065419,22.75 11,22.75 C17.4893458,22.75 22.75,17.4893458 22.75,11 C22.75,4.51065419 17.4893458,-0.75 11,-0.75 Z M11,0.75 C16.6609187,0.75 21.25,5.33908131 21.25,11 C21.25,16.6609187 16.6609187,21.25 11,21.25 C5.33908131,21.25 0.75,16.6609187 0.75,11 C0.75,5.33908131 5.33908131,0.75 11,0.75 Z"></path><path d="M11,5 C11.5128358,5 11.9355072,5.38604019 11.9932723,5.88337887 L12,6 L12,12 C12,12.5522847 11.5522847,13 11,13 C10.4871642,13 10.0644928,12.6139598 10.0067277,12.1166211 L10,12 L10,6 C10,5.44771525 10.4477153,5 11,5 Z"></path><circle cx="11" cy="16" r="1"></circle></g></g></svg>',
                    check: '<svg width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><g stroke-width="1"><path d="M17.4778906,7.4615747 C17.7752547,7.17322166 18.2500722,7.18052654 18.5384253,7.47789062 C18.8005644,7.7482216 18.8183582,8.16520834 18.5960129,8.45543389 L18.5221094,8.5384253 L9.74999944,17.0447132 L5.47789062,12.9020617 C5.18052654,12.6137086 5.17322166,12.1388911 5.4615747,11.841527 C5.72371384,11.571196 6.13995586,11.5405834 6.43688383,11.7538955 L6.52210938,11.8252111 L9.749,14.954 L17.4778906,7.4615747 Z"></path></g></svg>',
                    close: '<svg width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M5.96394924,5.60401752 C6.25684246,5.3111243 6.7317162,5.3111243 7.02460942,5.60401752 L7.02460942,5.60401752 L11.9992793,10.5783476 L16.9753906,5.60401752 C17.2682838,5.3111243 17.7431575,5.3111243 18.0360508,5.60401752 C18.328944,5.89691074 18.328944,6.37178447 18.0360508,6.66467769 L13.0602793,11.6393476 L17.9967532,16.5761613 C18.2630197,16.8424278 18.2872258,17.2590915 18.0693713,17.552703 L17.9967532,17.6368214 C17.7038599,17.9297147 17.2289862,17.9297147 16.936093,17.6368214 L16.936093,17.6368214 L11.9992793,12.7003476 L7.063907,17.6368214 C6.77101379,17.9297147 6.29614005,17.9297147 6.00324683,17.6368214 C5.71035361,17.3439282 5.71035361,16.8690545 6.00324683,16.5761613 L10.9382793,11.6393476 L5.96394924,6.66467769 C5.69768268,6.39841113 5.67347663,5.98174745 5.89133109,5.68813595 Z"></path></svg>'
                },
                markup: {
                    notifyTitle: 'p',
                    panelTitle: 'p'
                },
                styling: {
                    notifyTitle: 'display: none;',
                    notifyBody: 'font-weight: 200 !important; margin: 0; line-height: 24px;',
                    stickyHeader: 'font-weight: 200 !important;',
                    panelTitle: 'font-weight: 200 !important;',
                    panelBody: 'font-weight: 200 !important; margin: 16px 0;',
                    categoryTitle: 'font-weight: bold !important;',
                    categoryBody: 'font-weight: 200 !important; margin: 30px 0;',
                    alertTitle: 'font-weight: bold !important;',
                }
            },

            stickyHeader: true,
            stickyFooter: true,
            stickyFooterAlign: 'right',

            dropDowns: true,
            showNecessaryCheck: true,
            toggleType: 'switch',
            setInnerHTML: true,
        };

        CookieControl.load(config);

        function handleMutation(mutationsList) {
            const acceptAllEl = document.getElementById("ccc-notify-accept");
            const rejectAllEl = document.getElementById("ccc-notify-reject");
            const saveCloseBtn = document.querySelector("#ccc-footer button");
            let ccc_module = false;
            let notify_module = false;
            for (const mutation of mutationsList) {
                if (mutation.type === 'childList') {
                    const addedNodes = mutation.addedNodes;
                    for (const node of addedNodes) {
                        // console.log(node)
                        if (node.id === "ccc-module") {
                            ccc_module = true
                        }
                         if(node.id === "ccc-notify") {
                            // observer.disconnect();
                            // setupObserver();
                             notify_module = true
                        }
                    }
                }
            }

            if(ccc_module) {
                saveCloseBtn && saveCloseBtn.addEventListener("click", () => {
                    sendEvent("generic")
                });
                // setupObserver();
            }

            if(notify_module) {
                acceptAllEl && acceptAllEl.addEventListener("click", () => {
                    sendEvent("acceptAll")
                });

                rejectAllEl && rejectAllEl.addEventListener("click", () => {
                    sendEvent("rejectAll")
                });
            }
        }

        const observerConfig = { childList: true, subtree: true };

        function setupObserver() {
            const targetNode = document.body;
            const observer = new MutationObserver(handleMutation);
            observer.observe(targetNode, observerConfig);
        }

        setupObserver();

        let eventFired = false;
        function sendEvent(type){
            let analyticsProp = CookieControl.getCategoryConsent(0) || false
            let marketingProp = CookieControl.getCategoryConsent(1) || false

            if(type && type === "acceptAll") {
                analyticsProp = true
                marketingProp = true
            } else if(type && type === "rejectAll") {
                analyticsProp = false
                marketingProp = false
            }

            if (eventFired === false){
                console.log("event fired")
                // stop duplicate events in quick succession
                // important for accept all / subsequent page loads where analytics and marketing callbacks execute sequentially
                eventFired = true;
                // getCategoryConsent reads the cookie value, so give slight delay before executing
                // setTimeout(function () {
                const consent = {
                    'event': 'consent_status',
                    'analytics': analyticsProp,
                    'marketing': marketingProp
                }
                console.log(consent);
                // }, 200)
                window.dataLayer = window.dataLayer || [];
                window.dataLayer.push(consent);

                // reset global variable in case user changes their mind
                // setTimeout(function(){
                    eventFired = false
                // }, 0)
            }

        }

        function checkCookie(cookieName) {
            const allCookies = document.cookie;

            const cookiesArray = allCookies.split(';');

            for (let i = 0; i < cookiesArray.length; i++) {
                const cookie = cookiesArray[i].trim();

                if (cookie.indexOf(cookieName + '=') === 0) {
                    return true;
                }
            }
            return false;
        }

        const cookieExists = checkCookie('CookieControl');

        setTimeout(function() {
            if (cookieExists && (CookieControl.getCategoryConsent(0) || CookieControl.getCategoryConsent(1)) ) {
                sendEvent();
            }

        }, 1000);


        !cookieExists ? (async () => {
            const consent = {
                'event': 'consent_status',
            }
            console.log(consent);
            // }, 200)
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push(consent);
        })() : null

    })(jQuery);
});

</script>

    </body>
</html>
