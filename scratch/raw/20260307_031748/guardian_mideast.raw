      <pubDate>Fri, 06 Mar 2026 13:05:07 GMT</pubDate>
      <guid>https://www.theguardian.com/world/2026/mar/06/us-investigators-believe-strike-on-iranian-girls-school-likely-carried-out-by-us-forces</guid>
      <media:content width="140" url="https://i.guim.co.uk/img/media/2bf3b6e54474e26a5c8126b2a1b85369068063bd/806_0_4560_3648/master/4560.jpg?width=140&amp;quality=85&amp;auto=format&amp;fit=max&amp;s=8e074d5cb3405a1fa926b2d5dd15f11f">
        <media:credit scheme="urn:ebu">Photograph: Abbas Zakeri/Mehr News/WANA/Reuters</media:credit>
      </media:content>
      <media:content width="460" url="https://i.guim.co.uk/img/media/2bf3b6e54474e26a5c8126b2a1b85369068063bd/806_0_4560_3648/master/4560.jpg?width=460&amp;quality=85&amp;auto=format&amp;fit=max&amp;s=4e9a82710f8442a96d93939d8569916e">
        <media:credit scheme="urn:ebu">Photograph: Abbas Zakeri/Mehr News/WANA/Reuters</media:credit>
      </media:content>
