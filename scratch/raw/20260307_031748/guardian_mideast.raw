      <category domain="https://www.theguardian.com/us-news/us-news">US news</category>
      <pubDate>Fri, 06 Mar 2026 21:14:07 GMT</pubDate>
      <guid>https://www.theguardian.com/world/2026/mar/06/us-israel-threaten-major-escalation-airstrikes-iran-lebanon</guid>
      <media:content width="140" url="https://i.guim.co.uk/img/media/68d5b3d9ba86932dc74b1fd1d0f626a32860818c/0_0_1350_1080/master/1350.jpg?width=140&amp;quality=85&amp;auto=format&amp;fit=max&amp;s=558a86d91d2661223c6f59cc12221611">
