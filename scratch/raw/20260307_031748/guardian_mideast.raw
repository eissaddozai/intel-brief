      <media:content width="460" url="https://i.guim.co.uk/img/media/68d5b3d9ba86932dc74b1fd1d0f626a32860818c/0_0_1350_1080/master/1350.jpg?width=460&amp;quality=85&amp;auto=format&amp;fit=max&amp;s=c02ce54d9c6341dcf3e0e97a99bb791c">
        <media:credit scheme="urn:ebu">Photograph: Reuters</media:credit>
      </media:content>
