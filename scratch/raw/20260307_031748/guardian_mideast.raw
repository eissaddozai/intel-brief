      <media:content width="140" url="https://i.guim.co.uk/img/media/ad38a2e83b0cafba46b7f37fd7ff7f1f42b8a8e7/237_0_2667_2133/master/2667.jpg?width=140&amp;quality=85&amp;auto=format&amp;fit=max&amp;s=4a0d0009dbf98ae2b603158917049cb4">
        <media:credit scheme="urn:ebu">Photograph: Leon Neal/AP</media:credit>
      </media:content>
      <media:content width="460" url="https://i.guim.co.uk/img/media/ad38a2e83b0cafba46b7f37fd7ff7f1f42b8a8e7/237_0_2667_2133/master/2667.jpg?width=460&amp;quality=85&amp;auto=format&amp;fit=max&amp;s=bbef645b9532039851b3b354dcea61e4">
        <media:credit scheme="urn:ebu">Photograph: Leon Neal/AP</media:credit>
      </media:content>
      <media:content width="700" url="https://i.guim.co.uk/img/media/ad38a2e83b0cafba46b7f37fd7ff7f1f42b8a8e7/237_0_2667_2133/master/2667.jpg?width=700&amp;quality=85&amp;auto=format&amp;fit=max&amp;s=4b94e10fc8bc3ce11af4308943817312">
        <media:credit scheme="urn:ebu">Photograph: Leon Neal/AP</media:credit>
      </media:content>
