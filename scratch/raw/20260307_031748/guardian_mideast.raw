      <category domain="https://www.theguardian.com/us-news/us-news">US news</category>
      <category domain="https://www.theguardian.com/world/middleeast">Middle East and north Africa</category>
      <category domain="https://www.theguardian.com/world/world">World news</category>
      <pubDate>Fri, 06 Mar 2026 13:20:31 GMT</pubDate>
      <guid>https://www.theguardian.com/world/2026/mar/06/security-increase-iran-attack-us-israel-bombing</guid>
      <media:content width="140" url="https://i.guim.co.uk/img/media/32efe3a388a105760aaabb9fa0108e3e747201a8/195_0_2501_2000/master/2501.jpg?width=140&amp;quality=85&amp;auto=format&amp;fit=max&amp;s=80ef2790b06348bcb8db1b4ff57e6273">
        <media:credit scheme="urn:ebu">Photograph: Ryan Murphy/Getty Images</media:credit>
      </media:content>
      <media:content width="460" url="https://i.guim.co.uk/img/media/32efe3a388a105760aaabb9fa0108e3e747201a8/195_0_2501_2000/master/2501.jpg?width=460&amp;quality=85&amp;auto=format&amp;fit=max&amp;s=ee6f521f33771c4b48453a8e22ee66c9">
        <media:credit scheme="urn:ebu">Photograph: Ryan Murphy/Getty Images</media:credit>
      </media:content>
      <media:content width="700" url="https://i.guim.co.uk/img/media/32efe3a388a105760aaabb9fa0108e3e747201a8/195_0_2501_2000/master/2501.jpg?width=700&amp;quality=85&amp;auto=format&amp;fit=max&amp;s=e0b6a96cb7aefa761d9834947f7c05ab">
        <media:credit scheme="urn:ebu">Photograph: Ryan Murphy/Getty Images</media:credit>
      </media:content>
