        <media:credit scheme="urn:ebu">Photograph: Reuters</media:credit>
      </media:content>
      <dc:creator>Jason Burke in Jerusalem</dc:creator>
      <dc:date>2026-03-06T21:14:07Z</dc:date>
    </item>
