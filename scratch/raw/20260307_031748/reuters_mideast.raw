ications":true,"display_related_media":true,"display_related_organizations":true,"content_code":"metered","source":{"name":"Reuters","original_name":"Reuters"},"title":"Pakistani convicted of plotting to kill Trump over death of Iran commander","basic_headline":"Pakistani convicted of plotting to kill Trump over death of Iran commander","distributor":"Reuters","description":"A Pakistani man was convicted on Friday of planning to kill President Donald Trump and other prominent U.S. politicians two years ago at the behest ​of Iran, the Department of Justice said.","primary_media_type":"gallery","primary_tag":{"short_bio":"Criminal","description":"Criminal","slug":"nrlpa-ocrim","text":"NRLPA:OCRIM","is_topic":true,"can_follow":true,"is_legal":true,"topic_url":"/legal/criminal/"},"word_count":542,"read_minutes":3,"kicker":{"name":"Asia Pacific","path":"/world/asia-pacific/","names":["World","Asia Pacific"]},"ad_topics":["crime","pol","crime"],"thumbnail":{"url":"https://cloudfront-us-east-2.images.arcpublishing.com/reuters/IHHUI7BEYBNSNAIKODMTLQRAGU.jpg","caption":"Asif Merchant, a Pakistani man with alleged ties to Iran, appears on charges in connection with a foiled plot to assassinate a U.S. politician or government officials, in a courtroom in New York, U.S., September 16, 2024 in this courtroom sketch.    REUTERS/Jane Rosenberg/File Photo","type":"image","resizer_url":"https://www.reuters.com/resizer/v2/IHHUI7BEYBNSNAIKODMTLQRAGU.jpg?auth=f2198bc9f0a161fb0b4e18492423d0b50c7cbc8d0bf1e343eb0cbf1c7e2b5ebc","location":"NEW YORK, NY, UNITED STATES","id":"IHHUI7BEYBNSNAIKODMTLQRAGU","authors":"Jane Rosenberg","alt_text":"Asif Merchant, accused of joining Iran-led plot in 2024 to kill U.S. President Donald Trump","width":3000,"height":2250,"subtitle":"Asif Merchant, accused of joining Iran-led plot in 2024 to kill U.S. President Donald Trump","slug":"USA-TRUMP-IRAN-ASSASSINATE","updated_at":"2026-03-07T02:52:30Z","company":"Reuters","purchase_licensing_path":"https://www.