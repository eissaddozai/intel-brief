.jpg?auth=4dd3566d980534ddab2fb815cfdf9f08e04ca3d4f4dd0c88f6e42931b1e77167"},"social_links":[{"site":"email","url":"mailto:Pesha.Magid@thomsonreuters.com"}],"byline":"Pesha Magid","topic_url":"/authors/pesha-magid/"}],"display_time":"2026-03-06T03:53:20.013Z"},{"id":"BCPNEO4VFBJ5FAMER3NP2QQTSA","revision_id":"BWCFUX2P2BBKRPHYUY67CUDIHM","canonical_url":"/world/middle-east/irans-un-envoy-says-1332-iranian-civilians-killed-war-2026-03-06/","website":"reuters","web":"Iran's UN envoy says 1,332 Iranian civilians killed in war","native":"Iran's UN envoy says 1,332 Iranian civilians killed in war","published":true,"updated_time":"2026-03-06T23:16:51.305Z","published_time":"2026-03-06T21:18:21.67Z","article_type":"Standard","display_my_news":true,"display_newsletter_signup":true,"display_notifications":true,"display_related_media":true,"display_related_organizations":true,"content_code":"metered","source":{"name":"Reuters","original_name":"Reuters"},"title":"Iran's UN envoy says 1,332 Iranian civilians killed in war","basic_headline":"Iran's UN envoy says 1,332 Iranian civilians killed in war","distributor":"Reuters","description":"Iran's U.N. Ambassador Amir Saeid Iravani said on Friday that at least 1,332 Iranian civilians have died so far ​in the conflict with Israel and the U.S., and that thousands ‌more have been injured.","primary_media_type":"gallery","primary_tag":{"short_bio":"Human Rights","description":"Human Rights","slug":"rsbi-human-rights","text":"RSBI:HUMAN-RIGHTS","is_topic":true,"can_follow":true,"topic_url":"/sustainability/human-rights/"},"word_count":436,"read_minutes":3,"kicker":{"name":"Middle East","path":"/world/middle-east/","names":["World","Middle East"]},"ad_topics":["DeathInjrConft","engy","legal","pol","trade","DeathInjrConft"],"thumbnail":{"url":"https://cloudfront-us-east-2.images.arcpublishing.com/reuters/4QMUMWH4NFK5BK77SOI2VR5NNU.jpg","caption":"Smoke rises following an explosion, amid the U.S.-Israeli conflict with Iran, in Tehran, Iran