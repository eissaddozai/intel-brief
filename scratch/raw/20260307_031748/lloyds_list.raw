<style>
    #ll_subscription_form_modal {
        display: none;
        position: fixed;
        z-index: 999;
        padding-top: 100px;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        overflow: auto;
        background-color: rgba(0, 0, 0, 0.6);
    }
    #ll_subscription_form_modal .modal-content {
        background-color: #fefefe !important;
        margin: 0.5% auto;
        padding: 30px 50px;
        border: 1px solid #888;
        width: 60%;
        border-radius: 0.5rem;
        box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2), 0 6px 20px 0 rgba(0, 0, 0, 0.19);
        -webkit-animation-name: animatetop;
        -webkit-animation-duration: 0.4s;
        animation-name: animatetop;
        animation-duration: 0.4s;
    }
    #ll_subscription_form_modal .ll_close {
        color: #aaa;
        cursor: pointer;
        float: right !important;
        margin-left: auto;
        font-size: 30px;
        font-weight: 700;
    }
    #ll_subscription_form_modal h1 {
        font-size: 27px;
        font-weight: 700;
        color: #024;
        text-align: center;
    }
</style>
<div id="ll_subscription_form_modal" class="modal">
    <div class="form-content">
        <div class="modal-content">
            <span class="ll_close">&times;</span>
            <h1>Request a paid subscription</h1>
            <iframe id="ll_iframe" data-loaded="0" src="https://info.lloydslistintelligence.com/lloyds-list-request-subscription" width="100%" height="750px"
            ></iframe>
        </div>
    </div>
</div>
<script>
    let modal = document.getElementById("ll_subscription_form_modal");
    let btn1 = document.getElementsByClassName("btn-my-view")[0];
    let btn2 = document.querySelector(".article-call-to-action .button--filled:not(.article-call-to-action .js-login-container .button--filled)");
    let span = document.getElementsByClassName("ll_close")[0];

    if (typeof(btn1) != 'undefined' && btn1 != null){
        btn1.href = "#";
        btn1.onclick = function() {
            modal.style.display = "block";
        }
    }

    if (typeof(btn2) != 'undefined' && btn2 != null){
        btn2.href = "#";
        btn2.onclick = function() {
            modal.style.display = "block";
        }
    }

    span.onclick = function () {
        modal.style.display = "none";
    }

    window.onclick = function (l) {
        l.target == modal && (modal.style.display = "none");
    }

    // iframe on load
    document.getElementById("ll_iframe").onload = function(){
        var load_counter = this.getAttribute('data-loaded');
        load_counter++;
        this.setAttribute('data-loaded',load_counter);

        // redirect if load counter is 2
        if(load_counter == 2){
            setTimeout(function(){
                window.location.replace("https://www.lloydslist.com/request-subscription-thank-you-page");
            },1500);
        }
    }
</script>    




