        <script src="/lib/aon-lib.main.js?v=8iixHAPJwqVvh8njuSLy6xqlFJAwPPEYzRPxhmEpmm41"></script>

                <script>
         const element = document.querySelector(
             "[data-component='HomepageHeroV2']"
         );

         if (element) {
             const SELECTORS = {
                 SCROLL_LOADER_CONTENT: ".aon-homepage-hero__scroll-loader p",
                 SCROLL_LOADER_ARROW:
                     ".aon-homepage-hero__scroll-loader .arrow .aon-icon",
             };
             const scrollLoaderContent = element.querySelector(
                 SELECTORS.SCROLL_LOADER_CONTENT
             );
             const scrollLoaderArrow = element.querySelector(
                 SELECTORS.SCROLL_LOADER_ARROW
             );
             const defaultContent = scrollLoaderContent.textContent;

             const countdown = (callback, duration, onComplete) => {
                 let progress = 0;
                 let startTime;
                 let id;

                 const run = () => {
                     const elapsedTime = performance.now() - startTime;
                     progress = Math.min(elapsedTime / duration, 1);
                     callback(progress);

                     if (progress === 1) {
                         cancelAnimationFrame(id);
                         onComplete?.();
                     } else {
                         id = requestAnimationFrame(run);
                     }
                 };

                 const start = () => {
                     startTime = performance.now();
                     id = requestAnimationFrame(run);
                 };

                 const clear = () => {
                     cancelAnimationFrame(id);
                     id = undefined;
                 };

                 return {
                     clear,
                     start,
                 };
             };
             const { clear, start } = countdown(
                 (progress) => {
                     scrollLoaderContent.textContent = `${parseInt(
                         `${Math.min(progress * 100, 95)}`
                     )}%`;
                 },
                 5000,
                 () => {
                     clear();
                     start();
                 }
             );

             scrollLoaderArrow.addEventListener("animationstart", () => {
                 start();
             });
             scrollLoaderArrow.addEventListener("animationcancel", () => {
                 clear();
                 scrollLoaderContent.textContent = defaultContent;
             });

             if (window.matchMedia("(min-width: 1200px)").matches) {
                 document.body.style.overflow = "hidden";
             }
         }
</script>

