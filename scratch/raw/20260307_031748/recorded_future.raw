            <div>T1588.002</div>
          </div>
          <div>
            <div><strong>Resource Development:</strong> Compromise Accounts: Email Accounts</div>
            <div>T1586.002</div>
          </div>
          <div>
            <div><strong>Defense Evasion:</strong> Masquerading</div>
