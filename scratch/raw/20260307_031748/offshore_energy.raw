		<title>Green light for North Sea drilling ops with Odfjell Drilling-managed rig</title>
		<link>https://www.offshore-energy.biz/green-light-for-north-sea-drilling-ops-with-odfjell-drilling-managed-rig/</link>
		
		<dc:creator><![CDATA[Melisa Cavcic]]></dc:creator>
		<pubDate>Fri, 06 Mar 2026 11:18:19 +0000</pubDate>
				<category><![CDATA[Long read]]></category>
		<category><![CDATA[Deepsea Bollsta]]></category>
		<category><![CDATA[Equinor]]></category>
