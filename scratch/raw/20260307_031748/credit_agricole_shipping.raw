les/source_large_thumbnail_focal_point/public/shutterstock_2699249065_51430_CDN_images.jpg?h=c3b2fb4c\u0026itok=S8jIlbU0","source_thumbnail_focal_point":"http://bo-en-instit-cacib.adsi.credit-agricole.fr/sites/default/files/styles/source_thumbnail_focal_point/public/shutterstock_2699249065_51430_CDN_images.jpg?h=c3b2fb4c\u0026itok=O8Ypp80R"},"links":{"self":{"href":"http://bo-en-instit-cacib.adsi.credit-agricole.fr/en/jsonapi/file/file/5fc91ba5-de8e-435c-984f-95983ef55169"}},"resourceIdObjMeta":{"alt":null,"title":null,"width":4096,"height":4096,"drupal_internal__target_id":17692},"uid":{"type":"user--user","id":"be1166bb-7d30-46de-b087-689ab94ecacc","resourceIdObjMeta":{"drupal_internal__target_id":1}},"relationshipNames":["uid"]},"field_news_main_conten":[{"type":"paragraph--text_block_v1","id":"a8202a28-88a9-445d-968f-aa4756e28f89","resourceIdObjMeta":{"target_revision_id":288670,"drupal_internal__target_id":67155}},{"type":"paragraph--quote_block_v1","id":"0dd2323c-9497-4564-801e-50662cecfaef","resourceIdObjMeta":{"target_revision_id":288672,"drupal_internal__target_id":67157}},{"type":"paragraph--quote_block_v1","id":"8ef9d910-4f2e-4498-b1c7-018c9bf043a2","resourceIdObjMeta":{"target_revision_id":288674,"drupal_internal__target_id":67159}}],"field_right_content_data":[],"field_secondary_categories":[],"field_sectors":[{"type":"taxonomy_term--sectors","id":"8af0438c-f104-4de0-90da-5f54e7fcfff5","resourceIdObjMeta":{"drupal_internal__target_id":37}}],"relationshipNames":["node_type","revision_uid","uid","moderation_state","feeds_item","field_banner_image","field_categories","field_country","field_craft","field_domain_access","field_domain_source","field_edit_permission","field_free_tag","field_image","field_news_main_conten","field_right_content_data","field_secondary_categories","field_sectors"]}],"meta":{"count":4},"links":{"self":{"href":"http://bo-en-instit-cacib.adsi.credit-agricole.fr/en/jsonapi/views/news_list/block_news_highlight_more_link?include=field_i