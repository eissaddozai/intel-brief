etatag":true}},"schema_article_abstract_0":{"#tag":"meta","#attributes":{"name":"abstract","content":["The GlobalCapital MTN awards are determined by a market-wide poll of issuers","intermediaries and investors and as a result","are truly reflective of the market they represent."],"group":"schema_article","schema_metatag":true}},"schema_article_image":{"#tag":"meta","#attributes":{"name":"image","content":{"@type":"ImageObject","url":"http://bo-en-instit-cacib.adsi.credit-agricole.fr/sites/default/files/styles/large/public/55118701041_4fd58cf4b1_c_51466_CDN_images.jpg?itok=08-HneX-"},"group":"schema_article","schema_metatag":true}},"schema_article_date_published":{"#tag":"meta","#attributes":{"name":"datePublished","content":"2026-03-02T00:00:00+0100","group":"schema_article","schema_metatag":true}},"schema_article_date_modified":{"#tag":"meta","#attributes":{"name":"dateModified","content":"2026-03-03T12:05:01+0100","group":"schema_article","schema_metatag":true}},"schema_article_author_0":{"#tag":"meta","#attributes":{"name":"author","content":{"@type":"Organization","name":"Crédit Agricole CIB"},"group":"schema_article","schema_metatag":true}},"schema_article_publisher":{"#tag":"meta","#attributes":{"name":"publisher","content":{"@type":"Organization","name":"Crédit Agricole CIB"},"group":"schema_article","schema_metatag":true}},"schema_article_main_entity_of_page":{"#tag":"meta","#attributes":{"name":"mainEntityOfPage","content":"/en/news","group":"schema_article","schema_metatag":true}},"schema_video_object_type":{"#tag":"meta","#attributes":{"name":"@type","content":"VideoObject","group":"schema_video_object","schema_metatag":true}}}],"cacib_menu_tree":[],"body":{"value":"The GlobalCapital MTN awards are determined by a market-wide poll of issuers, intermediaries and investors and as a result, are truly reflective of the market they represent.","format":"full_html","processed":"\u003cp\u003eThe GlobalCapital MTN awards are determined by a market-wide poll of issuers, intermediaries and investors and as a result, are truly reflective of the market they represent.\u003c/p\u003e\n","summary":null},"field_anchor_link_title":null,"field_api_attachments":"\"\"","field_api_fields":"{\"content\":{\"body\":\"\\u003Cbody\\u003E\\u003Cfigure @class=\\u0022image\\u0022\\u003E\\u003Cimg @height=\\u0022533\\u0022 @src=\\u0022https:\\/\\/ca-cib.celum.cloud\\/55118701041_4fd58cf4b1_c_51466_CDN_images.jpg\\u0022 @style=\\u0022aspect-ratio:799\\/533;\\u0022 @width=\\u0022799\\u0022\\u003E\\u003C\\/img\\u003E\\u003C\\/figure\\u003E\\u003Clegend\\u003EFrom left to right: Edouard Sauce, Yannis Parant, Harpreet Parhar, Lorenzo Mendes, Toby Croasdell\\u003C\\/legend\\u003E\\u003Cp\\u003EIn addition to being voted \\u003Cstrong\\u003EMTN Bank of the Year\\u003C\\/strong\\u003E, the GMD MTNs (Medium-Term Notes) team was also recognised with 5 further awards:\\u003C\\/p\\u003E\\u003Cul\\u003E\\u003Cli\\u003E\\u003Cstrong\\u003EMost Innovative Bank of the Year\\u003C\\/strong\\u003E\\u003C\\/li\\u003E\\u003Cli\\u003E\\u003Cstrong\\u003EBest Bank for Introducing New Investors\\u00a0\\u003C\\/strong\\u003E\\u003C\\/li\\u003E\\u003Cli\\u003E\\u003Cstrong\\u003EBest Bank for ESG-linked MTNs\\u00a0\\u003C\\/strong\\u003E\\u003C\\/li\\u003E\\u003Cli\\u003E\\u003Cstrong\\u003EDeal of the Year - Korea Hydro and Nuclear Power\\u0027s HK$1.166bn green nuclear bond\\u00a0\\u003C\\/strong\\u003E\\u003C\\/li\\u003E\\u003Cli\\u003E\\u003Cstrong\\u003EOutstanding Individual Contribution: Toby Croasdell\\u003C\\/strong\\u003E\\u003C\\/li\\u003E\\u003C\\/ul\\u003E\\u003Cp\\u003E\\u003Ca @href=\\u0022Quote\\u0022\\u003EQuote\\u003C\\/a\\u003E\\u003C\\/p\\u003E\\u003C\\/body\\u003E\"},\"articleType\":\"Article\",\"category\":\"Awards \\u0026 Rankings\",\"thumbnailType\":\"Default\",\"introduction\":{\"body\":\"\\u003Cbody\\u003E\\u003Cp\\u003EThe GlobalCapital MTN awards are determined by a market-wide poll of issuers, intermediaries and investors and as a result, are truly reflective of the market they represent.\\u003C\\/p\\u003E\\u003C\\/body\\u003E\"},\"language\":\"EN\",\"job\":\"#GMD\",\"thumbnail\":\"51466---C1@@@https:\\/\\/ca-cib.celum.cloud\\/55118701041_4fd58cf4b1_c_51466_CDN_images.jpg\",\"quote\":{\"fields\":{\"ref-id\":\"Quote\",\"fullName\":\"Toby Croasdell\",\"text\":\"We\\u2019re delighted and slightly overwhelmed by the very kind recognition the market has provided for our ongoing efforts across the Global MTN \\u0026 PP arena. This is a cornerstone of our Primary markets offering and one where we continue to add real alpha for our issuer and investor clients alike. Thanks to you all for the partnership, the business, and the votes!\",\"avatarUrl\":\"https:\\/\\/ca-cib.celum.cloud\\/Toby-Croasdell_22508_CDN_images.jpg\",\"avatar\":\"22508---C1@@@https:\\/\\/ca-cib.celum.cloud\\/Toby-Croasdell_22508_CDN_images.jpg\",\"position\":\"Head of Syndicate for Corporate, Private Placements, Emerging Markets, ABS \\u0026 Head of MTNPP, and Head of London Syndicate\",\"alignment\":\"Align left\"}},\"thumbnailUrl\":\"https:\\/\\/ca-cib.celum.cloud\\/55118701041_4fd58cf4b1_c_51466_CDN_images.jpg\",\"publicationTargetDate\":\"2026-03-01T23:00:00.000Z\",\"publicationSites\":[\"Corporate Website ca-cib.com (external \\u2013 C1)\",\"Client Website Optimall (external \\u2013 C1)\"],\"confirmUsageAndRights\":true,\"mainTitle\":\"Cr\\u00e9dit Agricole CIB Global MTN team claims top title at the inaugural GlobalCapital MTN Awards\",\"publicationDate\":\"2026-03-01T23:00:00.000Z\"}","field_cms_id":"f492ea45-77a1-4f04-b886-9795c456a6c6","field_couleur_lisere":{"color":"#116F6A","opacity":null},"field_display_format":"default","field_domain_all_affiliates":false,"field_event_date":null,"field_event_end_date":null,"field_event_url":null,"field_external_link":false,"field_feed_body":"\u003cbody\u003e\u003cfigure class=\"image\"\u003e\u003cimg height=\"533\" src=\"https://ca-cib.celum.cloud/55118701041_4fd58cf4b1_c_51466_CDN_images.jpg\" style=\"aspect-ratio:799/533;\" width=\"799\"\u003e\u003c/img\u003e\u003c/figure\u003e\u003clegend\u003eFrom left to right: Edouard Sauce, Yannis Parant, Harpreet Parhar, Lorenzo Mendes, Toby Croasdell\u003c/legend\u003e\u003cp\u003eIn addition to being voted \u003cstrong\u003eMTN Bank of the Year\u003c/strong\u003e, the GMD MTNs (Medium-Term Notes) team was also recognised with 5 further awards:\u003c/p\u003e\u003cul\u003e\u003cli\u003e\u003cstrong\u003eMost Innovative Bank of the Year\u003c/strong\u003e\u003c/li\u003e\u003cli\u003e\u003cstrong\u003eBest Bank for Introducing New Investors \u003c/strong\u003e\u003c/li\u003e\u003cli\u003e\u003cstrong\u003eBest Bank for ESG-linked MTNs \u003c/strong\u003e\u003c/li\u003e\u003cli\u003e\u003cstrong\u003eDeal of the Year - Korea Hydro and Nuclear Power's HK$1.166bn green nuclear bond \u003c/strong\u003e\u003c/li\u003e\u003cli\u003e\u003cstrong\u003eOutstanding Individual Contribution: Toby Croasdell\u003c/strong\u003e\u003c/li\u003e\u003c/ul\u003e\u003cp\u003e\u003ca href=\"Quote\"\u003eQuote\u003c/a\u003e\u003c/p\u003e\u003c/body\u003e","field_meta_tag":null,"field_meta_tags":null,"field_news_types":"standard","field_publishing_date":"2026-03-02T00:00:00+01:00","field_resume":null,"field_send_to_client_portal":false,"field_small_title":null,"field_source_id":null,"field_url_link":null,"links":{"self":{"href":"http://bo-en-instit-cacib.adsi.credit-agricole.fr/en/jsonapi/node/actualite/8719d5bc-89f3-45d3-bc0b-914d6d238dac?resourceVersion=id%3A19413"},"working-copy":{"href":"http://bo-en-instit-cacib.adsi.credit-agricole.fr/en/jsonapi/node/actualite/8719d5bc-89f3-45d3-bc0b-914d6d238dac?resourceVersion=rel%3Aworking-copy"}},"node_type":{"type":"node_type--node_type","id":"5d383e81-8ea3-44ab-8639-bd3183ddc519","resourceIdObjMeta":{"drupal_internal__target_id":"actualite"}},"revision_uid":{"type":"user--user","id":"be1166bb-7d30-46de-b087-689ab94ecacc","resourceIdObjMeta":{"drupal_internal__target_id":1}},"uid":{"type":"use