&lt;tr&gt;
&lt;td&gt;2026-02-10&lt;/td&gt;
&lt;td&gt;1&lt;/td&gt;
&lt;td&gt;Original Release&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;2026-02-24&lt;/td&gt;
&lt;td&gt;2&lt;/td&gt;
&lt;td&gt;Initial CISA Republication of Schneider Electric SEVD-2026-041-02 advisory&lt;/td&gt;
&lt;/tr&gt;
&lt;/tbody&gt;
&lt;/table&gt;
&lt;hr&gt;
&lt;h2&gt;Legal Notice and Terms of Use&lt;/h2&gt;
</description>
