&lt;tr&gt;
&lt;td&gt;2026-02-24&lt;/td&gt;
&lt;td&gt;1&lt;/td&gt;
&lt;td&gt;Initial Publication&lt;/td&gt;
&lt;/tr&gt;
&lt;/tbody&gt;
&lt;/table&gt;
&lt;hr&gt;
