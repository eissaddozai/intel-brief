            <aside class="top-stories container hidden-xs" id="top-stories-container">
    <div class="header font-firasans">
        <span class="bl-6 b-color-4 color-black bold "><strong>TOP</strong></span> STORIES
    </div>
    <div class="content">
	<nav class="top-stories-nav">
                <div class="col-lg-3 col-md-3 col-sm-3 story-wrapper">
            <div class="story d-flex">
                <div class="image">
                    <a href="https://maritime-executive.com/article/third-us-training-ship-state-of-maine-delivered-to-marad" target="_blank">
                        <img src="https://maritime-executive.com/media/images/article/Photos/Navy_Govt_CoastGuard/State-of-Maine-dressed-for-naming-ceremony.jpg" 
             alt="State of Maine training ship" 
             class="img-responsive " 
              
             
                          loading="lazy" />
                        </a>
                </div>
