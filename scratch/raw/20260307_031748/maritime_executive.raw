                        $('#events_tbody').html(data);

                        $('.event_link', events).click(function () {

                            var link = $(this).data('link');

                            window.open(link);
                        });
                    });
                });

                $('.event_link', events).click(function () {

                    var link = $(this).data('link');

                    window.open(link);
                });
